<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .dashboard-title {
      font-weight: 700;
      color: #2563eb;
      letter-spacing: 1px;
      margin-bottom: 24px;
      text-align: center;
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-info {
      background: linear-gradient(90deg, #38bdf8 0%, #bae6fd 100%);
      border: none;
      color: #075985;
    }
    .btn-warning {
      background: linear-gradient(90deg, #f59e42 0%, #fef08a 100%);
      border: none;
      color: #92400e;
    }
    .table-striped > tbody > tr:nth-of-type(odd) {
      background-color: #f1f5f9;
    }
    .table th {
      background-color: #e0e7ef;
      color: #334155;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link disabled" href="#">Reports</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h1 class="dashboard-title"><i class="fa-solid fa-boxes-stacked me-2"></i>Products Dashboard</h1>
    <div class="d-flex justify-content-between align-items-center mb-3">
      <button type="button" id="add-product-modal-btn" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addProductModal">Add New Product</button>
      <div>
        <span id="update-status" class="text-muted me-2"></span>
        <button id="refresh-now" class="btn btn-sm btn-outline-secondary">Refresh Now</button>
      </div>
    </div>

    <!-- Add Product Modal -->
    <div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <form id="add-product-form">
            <div class="modal-header">
              <h5 class="modal-title" id="addProductModalLabel">Add New Product</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label for="modal-category" class="form-label">Category</label>
                  <input type="text" class="form-control" id="modal-category" name="category" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-name" class="form-label">Product Name</label>
                  <input type="text" class="form-control" id="modal-name" name="name" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-supplier" class="form-label">Supplier</label>
                  <input type="text" class="form-control" id="modal-supplier" name="supplier" required>
                </div>
                <div class="col-12">
                  <label class="form-label">Sizes & Stock</label>
                  <div id="modal-sizes-container">
                    <div class="row mb-2 modal-size-row">
                      <div class="col-md-5">
                        <select class="form-control" name="sizes[0][size]">
                          <option value="">Select Size</option>
                          <option value="S">S</option>
                          <option value="M">M</option>
                          <option value="L">L</option>
                          <option value="XL">XL</option>
                          <option value="XXL">XXL</option>
                        </select>
                      </div>
                      <div class="col-md-5">
                        <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity">
                      </div>
                      <div class="col-md-2">
                        <button type="button" class="btn btn-danger remove-modal-size-row" style="display:none;">Remove</button>
                      </div>
                    </div>
                  </div>
                  <button type="button" class="btn btn-primary mt-2" id="add-modal-size-row">Add Size</button>
                </div>
                <div class="col-md-4">
                  <label for="modal-cost_price" class="form-label">Cost Price (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-cost_price" name="cost_price" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-margin_percent" class="form-label">Margin (%)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-margin_percent" name="margin_percent" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-margin_rs" class="form-label">Margin (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-margin_rs" name="margin_rs" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-selling_price" class="form-label">Selling Price (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-selling_price" name="selling_price" required>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-success">Save Product</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <form id="bulk-delete-form" method="POST" action="/products/bulk-delete" onsubmit="return confirm('Are you sure you want to delete the selected products? This action cannot be undone.');">
      <div class="mb-2">
        <input type="checkbox" id="select-all"> <label for="select-all" class="ms-1">Select All</label>
      </div>
      <table class="table table-striped">
        <thead>
          <tr>
            <th></th>
            <th>Product Code</th>
            <th>Category</th>
            <th>Name</th>
            <th>Supplier</th>
            <th>Sizes & Stock</th>
            <th>Cost Price (₹)</th>
            <th>Margin (%)</th>
            <th>Margin (₹)</th>
            <th>Selling Price (₹)</th>
            <th>QR Code</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="products-table-body">
          <!-- Data populated dynamically by JavaScript -->
        </tbody>
        <!-- Inline Add Product Row (hidden by default) -->
        <tr id="inline-add-row" style="display:none; background:#e6f7ff;">
          <td></td>
          <td><input type="text" id="inline-product_code" placeholder="Product Code" class="form-control"></td>
          <td><input type="text" id="inline-category" placeholder="Category" class="form-control"></td>
          <td><input type="text" id="inline-name" placeholder="Name" class="form-control"></td>
          <td><input type="text" id="inline-supplier" placeholder="Supplier" class="form-control"></td>
          <td></td>
          <td><input type="number" id="inline-cost_price" placeholder="Cost Price" class="form-control"></td>
          <td><input type="number" id="inline-margin_percent" placeholder="Margin %" class="form-control"></td>
          <td><input type="number" id="inline-margin_rs" placeholder="Margin ₹" class="form-control"></td>
          <td><input type="number" id="inline-selling_price" placeholder="Selling Price" class="form-control"></td>
          <td></td>
          <td class="actions">
            <button id="save-inline-product" class="btn btn-success btn-sm">Save</button>
            <button id="cancel-inline-product" type="button" class="btn btn-secondary btn-sm">Cancel</button>
          </td>
        </tr>
      </table>
      <button type="submit" class="btn btn-danger" id="bulk-delete-btn" disabled>Delete Selected</button>
    </form>
  </div>

  <script src="/socket.io/socket.io.js"></script>
    <script>
      // Modal size row logic
      let modalSizeIndex = 1;
      document.getElementById('add-modal-size-row').addEventListener('click', function() {
        const container = document.getElementById('modal-sizes-container');
        const newRow = document.createElement('div');
        newRow.className = 'row mb-2 modal-size-row';
        newRow.innerHTML = `
          <div class="col-md-5">
            <select class="form-control" name="sizes[${modalSizeIndex}][size]">
              <option value="">Select Size</option>
              <option value="S">S</option>
              <option value="M">M</option>
              <option value="L">L</option>
              <option value="XL">XL</option>
              <option value="XXL">XXL</option>
            </select>
          </div>
          <div class="col-md-5">
            <input type="number" class="form-control" name="sizes[${modalSizeIndex}][stock]" placeholder="Quantity">
          </div>
          <div class="col-md-2">
            <button type="button" class="btn btn-danger remove-modal-size-row">Remove</button>
          </div>
        `;
        container.appendChild(newRow);
        updateModalRemoveButtons();
        modalSizeIndex++;
      });
      function updateModalRemoveButtons() {
        const rows = document.querySelectorAll('.modal-size-row');
        rows.forEach((row, idx) => {
          const btn = row.querySelector('.remove-modal-size-row');
          if (btn) btn.style.display = rows.length > 1 ? '' : 'none';
          btn && btn.addEventListener('click', function() {
            row.remove();
            updateModalRemoveButtons();
          });
        });
      }
      updateModalRemoveButtons();

      // Handle add product form submit
      document.getElementById('add-product-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        const form = e.target;
        const formData = new FormData(form);
        // Convert FormData to JSON
        const data = {};
        formData.forEach((value, key) => {
          // Handle nested sizes[]
          if (key.startsWith('sizes[')) {
            const match = key.match(/sizes\[(\d+)\]\[(\w+)\]/);
            if (match) {
              const idx = match[1];
              const field = match[2];
              data.sizes = data.sizes || {};
              data.sizes[idx] = data.sizes[idx] || {};
              data.sizes[idx][field] = value;
            }
          } else {
            data[key] = value;
          }
        });
        // Convert sizes object to array
        if (data.sizes) {
          data.sizes = Object.values(data.sizes);
        }
        try {
          const res = await fetch('/products/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (res.ok) {
            // Hide modal, refresh products
            const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('addProductModal'));
            modal.hide();
            fetchProducts();
            form.reset();
            // Reset sizes
            document.getElementById('modal-sizes-container').innerHTML = `<div class="row mb-2 modal-size-row">
              <div class="col-md-5">
                <select class="form-control" name="sizes[0][size]">
                  <option value="">Select Size</option>
                  <option value="S">S</option>
                  <option value="M">M</option>
                  <option value="L">L</option>
                  <option value="XL">XL</option>
                  <option value="XXL">XXL</option>
                </select>
              </div>
              <div class="col-md-5">
                <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity">
              </div>
              <div class="col-md-2">
                <button type="button" class="btn btn-danger remove-modal-size-row" style="display:none;">Remove</button>
              </div>
            </div>`;
            modalSizeIndex = 1;
            updateModalRemoveButtons();
          } else {
            alert('Error saving product');
          }
        } catch (err) {
          alert('Network error');
        }
      });
    </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // ========== Helper functions for selection persistence ==========
    function getSelectedProductIds() {
      try {
        return JSON.parse(localStorage.getItem('selectedProductIds') || '[]');
      } catch { return []; }
    }
    function setSelectedProductIds(ids) {
      localStorage.setItem('selectedProductIds', JSON.stringify(ids));
    }

    // Update bulk delete button state
    function updateBulkDeleteBtn() {
      const checked = document.querySelectorAll('.product-checkbox:checked').length;
      document.getElementById('bulk-delete-btn').disabled = checked === 0;
    }

    // Update "Select All" checkbox state
    function updateSelectAllCheckbox() {
      const checkboxes = document.querySelectorAll('.product-checkbox');
      const checked = document.querySelectorAll('.product-checkbox:checked').length;
      const selectAll = document.getElementById('select-all');
      selectAll.checked = checkboxes.length > 0 && checked === checkboxes.length;
      selectAll.indeterminate = checked > 0 && checked < checkboxes.length;
    }

    // ========== Fetch products from API and rebuild table ==========
    async function fetchProducts() {
      try {
        const response = await fetch('/api/products?_=' + Date.now());
        if (!response.ok) throw new Error('Failed to fetch');
        const products = await response.json();

        const selectedIds = new Set(getSelectedProductIds());
        const tbody = document.getElementById('products-table-body');

        if (products.length === 0) {
          tbody.innerHTML = '<tr><td colspan="13" class="text-center">No products found.</td></tr>';
        } else {
          tbody.innerHTML = products.map(product => `
            <tr>
              <td><input type="checkbox" class="product-checkbox" name="productIds[]" value="${product.id}" ${selectedIds.has(product.id) ? 'checked' : ''}></td>
              <td>${product.product_code}</td>
              <td>${product.category}</td>
              <td>${product.name}</td>
              <td>${product.supplier}</td>
              <td>
                ${product.variants && product.variants.length > 0
                  ? product.variants.map(v => `${v.size}: ${v.stock}`).join('<br>')
                  : '<span class="text-muted">—</span>'}
              </td>
              <td>₹${product.cost_price}</td>
              <td>${product.margin_percent}%</td>
              <td>${product.margin_rs}</td>
              <td>₹${product.selling_price}</td>
              <td>
                <a href="/products/${product.id}">
                  <img src="/api/qr/${product.qr_code}" alt="QR" style="width: 50px; height: 50px;">
                </a>
              </td>
              <td>
                <a href="/products/${product.id}" class="btn btn-sm btn-info">View</a>
                <a href="/products/edit/${product.id}" class="btn btn-sm btn-warning">Edit</a>
                <form method="POST" action="/products/delete/${product.id}" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');">
                  <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          `).join('');
        }

        // Re‑apply selection and update UI
        updateBulkDeleteBtn();
        updateSelectAllCheckbox();
        document.getElementById('update-status').innerText = `Last updated: ${new Date().toLocaleTimeString()}`;
      } catch (error) {
        console.error(error);
        document.getElementById('products-table-body').innerHTML = '<tr><td colspan="13" class="text-center text-danger">Error loading products</td></tr>';
      }
    }

    // ========== Event Listeners (attached once on page load) ==========
    document.addEventListener('DOMContentLoaded', function() {
      // Initial load
      fetchProducts();

      // Socket.io for real‑time updates
      const socket = io();
      socket.on('products-updated', fetchProducts);

      // Manual refresh button
      document.getElementById('refresh-now').addEventListener('click', fetchProducts);

      // "Select All" checkbox
      const selectAll = document.getElementById('select-all');
      selectAll.addEventListener('change', function() {
        const checkboxes = document.querySelectorAll('.product-checkbox');
        checkboxes.forEach(cb => { cb.checked = selectAll.checked; });
        const ids = Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
        setSelectedProductIds(ids);
        updateBulkDeleteBtn();
      });

      // Delegate change events on checkboxes (inside tbody)
      document.getElementById('products-table-body').addEventListener('change', function(e) {
        if (e.target.classList.contains('product-checkbox')) {
          const checkboxes = document.querySelectorAll('.product-checkbox');
          const ids = Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
          setSelectedProductIds(ids);
          updateBulkDeleteBtn();
          updateSelectAllCheckbox();
        }
      });

      // Inline Add: show row
      document.getElementById('add-inline-product').addEventListener('click', function() {
        document.getElementById('inline-add-row').style.display = '';
        this.disabled = true;
      });

      // Inline Add: cancel
      document.getElementById('cancel-inline-product').addEventListener('click', function() {
        document.getElementById('inline-add-row').style.display = 'none';
        document.getElementById('add-inline-product').disabled = false;
        // Clear input fields
        document.getElementById('inline-product_code').value = '';
        document.getElementById('inline-category').value = '';
        document.getElementById('inline-name').value = '';
        document.getElementById('inline-supplier').value = '';
        document.getElementById('inline-cost_price').value = '';
        document.getElementById('inline-margin_percent').value = '';
        document.getElementById('inline-margin_rs').value = '';
        document.getElementById('inline-selling_price').value = '';
      });

      // Inline Add: save
      document.getElementById('save-inline-product').addEventListener('click', function() {
        const name = document.getElementById('inline-name').value.trim();
        const category = document.getElementById('inline-category').value.trim();
        const supplier = document.getElementById('inline-supplier').value.trim();
        const cost_price = document.getElementById('inline-cost_price').value.trim();
        const margin_percent = document.getElementById('inline-margin_percent').value.trim();
        const margin_rs = document.getElementById('inline-margin_rs').value.trim();
        const selling_price = document.getElementById('inline-selling_price').value.trim();

        if (!name || !category || !supplier || !cost_price || !margin_percent || !margin_rs || !selling_price) {
          alert('Please fill all fields');
          return;
        }

        fetch('/products/inline-add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, category, supplier, cost_price, margin_percent, margin_rs, selling_price })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            // Refresh the product list
            fetchProducts();
            // Hide inline row and re‑enable add button
            document.getElementById('inline-add-row').style.display = 'none';
            document.getElementById('add-inline-product').disabled = false;
            // Clear fields
            document.getElementById('inline-product_code').value = '';
            document.getElementById('inline-category').value = '';
            document.getElementById('inline-name').value = '';
            document.getElementById('inline-supplier').value = '';
            document.getElementById('inline-cost_price').value = '';
            document.getElementById('inline-margin_percent').value = '';
            document.getElementById('inline-margin_rs').value = '';
            document.getElementById('inline-selling_price').value = '';
          } else {
            alert('Error: ' + (data.error || 'Could not add product'));
          }
        })
        .catch(() => alert('Network error'));
      });
    });
  </script>
</body>
</html>