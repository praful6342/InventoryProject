<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .dashboard-title {
      font-weight: 700;
      color: #2563eb;
      letter-spacing: 1px;
      margin-bottom: 24px;
      text-align: center;
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-info {
      background: linear-gradient(90deg, #38bdf8 0%, #bae6fd 100%);
      border: none;
      color: #075985;
    }
    .btn-warning {
      background: linear-gradient(90deg, #f59e42 0%, #fef08a 100%);
      border: none;
      color: #92400e;
    }
    .table-striped > tbody > tr:nth-of-type(odd) {
      background-color: #f1f5f9;
    }
    .table th {
      background-color: #e0e7ef;
      color: #334155;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link active" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/sale/cart">Cart</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h1 class="dashboard-title"><i class="fa-solid fa-boxes-stacked me-2"></i>Products Dashboard</h1>

    <!-- Totals Card -->
    <div class="row mb-4">
      <div class="col-md-6">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Cost Price of All Products</h5>
            <p class="display-6 text-warning" id="totalCostPrice">₹0.00</p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Selling Price of All Products</h5>
            <p class="display-6 text-info" id="totalSellingPrice">₹0.00</p>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <button type="button" id="add-product-modal-btn" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addProductModal">Add New Product</button>
      <div>
        <span id="update-status" class="text-muted me-2"></span>
        <button id="refresh-now" class="btn btn-sm btn-outline-secondary">Refresh Now</button>
      </div>
    </div>

    <!-- Add Product Modal -->
    <div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <form id="add-product-form">
            <div class="modal-header">
              <h5 class="modal-title" id="addProductModalLabel">Add New Product</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label for="modal-category" class="form-label">Category</label>
                  <input type="text" class="form-control" id="modal-category" name="category" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-name" class="form-label">Product Name</label>
                  <input type="text" class="form-control" id="modal-name" name="name" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-supplier" class="form-label">Supplier</label>
                  <input type="text" class="form-control" id="modal-supplier" name="supplier" required>
                </div>
                <div class="col-12">
                  <label class="form-label">Sizes & Stock</label>
                  <div id="modal-sizes-container">
                    <div class="row mb-2 modal-size-row">
                      <div class="col-md-5">
                        <select class="form-control" name="sizes[0][size]">
                          <option value="">Select Size</option>
                          <option value="S">S</option>
                          <option value="M">M</option>
                          <option value="L">L</option>
                          <option value="XL">XL</option>
                          <option value="XXL">XXL</option>
                        </select>
                      </div>
                      <div class="col-md-5">
                        <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity">
                      </div>
                      <div class="col-md-2">
                        <button type="button" class="btn btn-danger remove-modal-size-row" style="display:none;">Remove</button>
                      </div>
                    </div>
                  </div>
                  <button type="button" class="btn btn-primary mt-2" id="add-modal-size-row">Add Size</button>
                </div>
                <div class="col-md-4">
                  <label for="modal-cost_price" class="form-label">Cost Price (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-cost_price" name="cost_price" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-margin_percent" class="form-label">Margin (%)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-margin_percent" name="margin_percent" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-margin_rs" class="form-label">Margin (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-margin_rs" name="margin_rs" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-selling_price" class="form-label">Selling Price (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-selling_price" name="selling_price" required>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-success">Save Product</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <table class="table table-striped">
      <thead>
        <tr>
          <th>Product Code</th>
          <th>Category</th>
          <th>Name</th>
          <th>Supplier</th>
          <th>Sizes & Stock</th>
          <th>Cost Price (₹)</th>
          <th>Margin (%)</th>
          <th>Margin (₹)</th>
          <th>Selling Price (₹)</th>
          <th>QR Code</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody id="products-table-body">
        <!-- Data populated dynamically by JavaScript -->
      </tbody>
    </table>
  </div>

  <%- include('../partials/footer') %>

  <script src="/socket.io/socket.io.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Modal size row logic
    let modalSizeIndex = 1;
    document.getElementById('add-modal-size-row').addEventListener('click', function() {
      const container = document.getElementById('modal-sizes-container');
      const newRow = document.createElement('div');
      newRow.className = 'row mb-2 modal-size-row';
      newRow.innerHTML = `
        <div class="col-md-5">
          <select class="form-control" name="sizes[${modalSizeIndex}][size]">
            <option value="">Select Size</option>
            <option value="S">S</option>
            <option value="M">M</option>
            <option value="L">L</option>
            <option value="XL">XL</option>
            <option value="XXL">XXL</option>
          </select>
        </div>
        <div class="col-md-5">
          <input type="number" class="form-control" name="sizes[${modalSizeIndex}][stock]" placeholder="Quantity">
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-danger remove-modal-size-row">Remove</button>
        </div>
      `;
      container.appendChild(newRow);
      updateModalRemoveButtons();
      modalSizeIndex++;
    });

    function updateModalRemoveButtons() {
      const rows = document.querySelectorAll('.modal-size-row');
      rows.forEach((row, idx) => {
        const btn = row.querySelector('.remove-modal-size-row');
        if (btn) btn.style.display = rows.length > 1 ? '' : 'none';
        btn && btn.addEventListener('click', function() {
          row.remove();
          updateModalRemoveButtons();
        });
      });
    }
    updateModalRemoveButtons();

    // Handle add product form submit with toasts
    document.getElementById('add-product-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      const form = e.target;
      const formData = new FormData(form);
      const data = {};
      formData.forEach((value, key) => {
        if (key.startsWith('sizes[')) {
          const match = key.match(/sizes\[(\d+)\]\[(\w+)\]/);
          if (match) {
            const idx = match[1];
            const field = match[2];
            data.sizes = data.sizes || {};
            data.sizes[idx] = data.sizes[idx] || {};
            data.sizes[idx][field] = value;
          }
        } else {
          data[key] = value;
        }
      });
      if (data.sizes) {
        data.sizes = Object.values(data.sizes);
      }
      try {
        const res = await fetch('/products/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        if (res.ok) {
          const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('addProductModal'));
          modal.hide();
          fetchProducts();
          form.reset();
          document.getElementById('modal-sizes-container').innerHTML = `<div class="row mb-2 modal-size-row">
            <div class="col-md-5">
              <select class="form-control" name="sizes[0][size]">
                <option value="">Select Size</option>
                <option value="S">S</option>
                <option value="M">M</option>
                <option value="L">L</option>
                <option value="XL">XL</option>
                <option value="XXL">XXL</option>
              </select>
            </div>
            <div class="col-md-5">
              <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity">
            </div>
            <div class="col-md-2">
              <button type="button" class="btn btn-danger remove-modal-size-row" style="display:none;">Remove</button>
            </div>
          </div>`;
          modalSizeIndex = 1;
          updateModalRemoveButtons();
          showToast('Product added successfully!', 'success');
        } else {
          showToast('Error saving product', 'danger');
        }
      } catch (err) {
        console.error(err);
        showToast('Network error', 'danger');
      }
    });

    async function fetchProducts() {
      try {
        const response = await fetch('/api/products?_=' + Date.now());
        if (!response.ok) throw new Error('Failed to fetch');
        const products = await response.json();

        const tbody = document.getElementById('products-table-body');

        // Calculate totals
        let totalCost = 0, totalSelling = 0;
        products.forEach(product => {
          const costPrice = parseFloat(product.cost_price) || 0;
          const sellingPrice = parseFloat(product.selling_price) || 0;
          if (product.variants && product.variants.length > 0) {
            product.variants.forEach(variant => {
              const stock = parseInt(variant.stock) || 0;
              totalCost += costPrice * stock;
              totalSelling += sellingPrice * stock;
            });
          }
        });
        document.getElementById('totalCostPrice').innerText = `₹${totalCost.toFixed(2)}`;
        document.getElementById('totalSellingPrice').innerText = `₹${totalSelling.toFixed(2)}`;

        if (products.length === 0) {
          tbody.innerHTML = '<tr><td colspan="11" class="text-center">No products found.</td></tr>';
        } else {
          tbody.innerHTML = products.map(product => `
            <tr>
              <td>${product.product_code}</td>
              <td>${product.category}</td>
              <td>${product.name}</td>
              <td>${product.supplier}</td>
              <td>
                ${product.variants && product.variants.length > 0
                  ? product.variants.map(v => `${v.size}: ${v.stock}`).join('<br>')
                  : '<span class="text-muted">—</span>'}
              </td>
              <td>₹${product.cost_price}</td>
              <td>${product.margin_percent}%</td>
              <td>${product.margin_rs}</td>
              <td>₹${product.selling_price}</td>
              <td>
                <a href="/products/${product.id}">
                  <img src="/api/qr/${product.qr_code}" alt="QR" style="width: 50px; height: 50px;">
                </a>
              </td>
              <td>
                <a href="/products/${product.id}" class="btn btn-sm btn-info">View</a>
                <a href="/products/edit/${product.id}" class="btn btn-sm btn-warning">Edit</a>
                <!-- Delete button removed -->
              </td>
            </tr>
          `).join('');
        }

        document.getElementById('update-status').innerText = `Last updated: ${new Date().toLocaleTimeString()}`;
      } catch (error) {
        console.error(error);
        document.getElementById('products-table-body').innerHTML = '<tr><td colspan="11" class="text-center text-danger">Error loading products</td></tr>';
        showToast('Error loading products', 'danger');
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      fetchProducts();

      const socket = io();
      socket.on('products-updated', fetchProducts);

      document.getElementById('refresh-now').addEventListener('click', fetchProducts);
    });
  </script>
</body>
</html>