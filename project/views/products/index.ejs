<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .dashboard-title {
      font-weight: 700;
      color: #2563eb;
      letter-spacing: 1px;
      margin-bottom: 24px;
      text-align: center;
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-info {
      background: linear-gradient(90deg, #38bdf8 0%, #bae6fd 100%);
      border: none;
      color: #075985;
    }
    .btn-warning {
      background: linear-gradient(90deg, #f59e42 0%, #fef08a 100%);
      border: none;
      color: #92400e;
    }
    .table-striped > tbody > tr:nth-of-type(odd) {
      background-color: #f1f5f9;
    }
    .table th {
      background-color: #e0e7ef;
      color: #334155;
      font-weight: 600;
    }
    /* Make entire row clickable */
    .clickable-row {
      cursor: pointer;
      transition: background-color 0.2s;
    }
    .clickable-row:hover {
      background-color: #dbeafe !important;
    }
  </style>
</head>
<body>

  <%- include('../partials/navbar', { currentPage: 'products' }) %>

  <div class="container mt-4">
    <h1 class="dashboard-title"><i class="fa-solid fa-boxes-stacked me-2"></i>Products Dashboard</h1>

    <!-- Totals Card -->
    <div class="row mb-4">
      <div class="col-md-6">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Cost Price of All Products</h5>
            <p class="display-6 text-warning" id="totalCostPrice">₹0.00</p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Selling Price of All Products</h5>
            <p class="display-6 text-info" id="totalSellingPrice">₹0.00</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Filter row -->
    <div class="row mb-3">
      <div class="col-md-4">
        <input type="text" id="search-input" class="form-control" placeholder="Search by name, code, category, supplier...">
      </div>
      <div class="col-md-3">
        <select id="category-filter" class="form-select">
          <option value="">All Categories</option>
          <!-- options populated dynamically from products -->
        </select>
      </div>
      <div class="col-md-3">
        <select id="size-filter" class="form-select">
          <option value="">All Sizes</option>
          <option value="S">S</option>
          <option value="M">M</option>
          <option value="L">L</option>
          <option value="XL">XL</option>
          <option value="2XL">2XL</option>
          <option value="3XL">3XL</option>
          <option value="4XL">4XL</option>
          <option value="5XL">5XL</option>
        </select>
      </div>
      <div class="col-md-2">
        <button id="clear-filters" class="btn btn-outline-secondary w-100">Clear</button>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <% if (user && user.role === 'admin') { %>
        <button type="button" id="add-product-modal-btn" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addProductModal">Add New Product</button>
      <% } else { %>
        <div></div>
      <% } %>
      <div>
        <span id="update-status" class="text-muted me-2"></span>
        <button id="refresh-now" class="btn btn-sm btn-outline-secondary">Refresh Now</button>
      </div>
    </div>

    <!-- Add Product Modal -->
    <div class="modal fade" id="addProductModal" tabindex="-1" aria-labelledby="addProductModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-lg">
        <div class="modal-content">
          <form id="add-product-form">
            <div class="modal-header">
              <h5 class="modal-title" id="addProductModalLabel">Add New Product</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <!-- Category with datalist -->
              <div class="row g-3">
                <div class="col-md-4">
                  <label for="modal-category" class="form-label">Category</label>
                  <input type="text" class="form-control" id="modal-category" name="category" required list="category-list">
                  <datalist id="category-list"></datalist>
                </div>
                <div class="col-md-4">
                  <label for="modal-name" class="form-label">Product Name</label>
                  <input type="text" class="form-control" id="modal-name" name="name" required list="product-names">
                  <datalist id="product-names"></datalist>
                </div>
                <div class="col-md-4">
                  <label for="modal-supplier" class="form-label">Supplier</label>
                  <input type="text" class="form-control" id="modal-supplier" name="supplier" required list="supplier-list">
                  <datalist id="supplier-list"></datalist>
                </div>
              </div>

              <!-- Created At (optional manual date) -->
              <div class="row g-3 mt-2">
                <div class="col-md-4">
                  <label for="modal-created_at" class="form-label">Added On (optional)</label>
                  <input type="date" class="form-control" id="modal-created_at" name="created_at">
                  <small class="text-muted">Leave blank for current date/time</small>
                </div>
              </div>

              <!-- Has Sizes Checkbox -->
              <div class="mb-3 form-check mt-3">
                <input type="checkbox" class="form-check-input" id="modal-hasSizes" name="has_sizes" value="on" checked>
                <label class="form-check-label" for="modal-hasSizes">This product has sizes (S, M, L, XL, 2XL, 3XL, 4XL, 5XL)</label>
              </div>

              <!-- Sizes Section -->
              <div id="modal-sizes-section">
                <div class="mb-3">
                  <label class="form-label">Sizes & Stock</label>
                  <div id="modal-sizes-container">
                    <div class="row mb-2 modal-size-row">
                      <div class="col-md-5">
                        <select class="form-control" name="sizes[0][size]">
                          <option value="">Select Size</option>
                          <option value="S">S</option>
                          <option value="M">M</option>
                          <option value="L">L</option>
                          <option value="XL">XL</option>
                          <option value="2XL">2XL</option>
                          <option value="3XL">3XL</option>
                          <option value="4XL">4XL</option>
                          <option value="5XL">5XL</option>
                        </select>
                      </div>
                      <div class="col-md-5">
                        <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity">
                      </div>
                      <div class="col-md-2">
                        <button type="button" class="btn btn-danger remove-modal-size-row" style="display:none;">Remove</button>
                      </div>
                    </div>
                  </div>
                  <button type="button" class="btn btn-primary mt-2" id="add-modal-size-row">Add Size</button>
                </div>
              </div>

              <!-- Single Stock Section -->
              <div id="modal-single-stock-section" class="mb-3" style="display: none;">
                <label for="modal-stock" class="form-label">Stock (units)</label>
                <input type="number" class="form-control" id="modal-stock" name="stock" min="0">
              </div>

              <!-- Price Fields -->
              <div class="row g-3 mt-2">
                <div class="col-md-4">
                  <label for="modal-cost_price" class="form-label">Cost Price (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-cost_price" name="cost_price" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-margin_percent" class="form-label">Margin (%)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-margin_percent" name="margin_percent" required>
                </div>
                <div class="col-md-4">
                  <label for="modal-margin_rs" class="form-label">Margin (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-margin_rs" name="margin_rs" readonly>
                </div>
                <div class="col-md-4">
                  <label for="modal-selling_price" class="form-label">Selling Price (₹)</label>
                  <input type="number" step="0.01" class="form-control" id="modal-selling_price" name="selling_price" readonly>
                </div>
              </div>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-success">Save Product</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-striped table-sm align-middle mb-0 products-table">
        <thead class="table-light">
          <tr>
            <th>Product Code</th>
            <th>Category</th>
            <th>Name</th>
            <th>Supplier</th>
            <th>Sizes & Stock</th>
            <th>Cost Price (₹)</th>
            <th>Margin (%)</th>
            <th>Margin (₹)</th>
            <th>Selling Price (₹)</th>
            <th>Added On</th>
            <th>Age (days)</th>
            <th>QR Code</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="products-table-body">
          <!-- populated by JS -->
        </tbody>
      </table>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="/socket.io/socket.io.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // ========== POPULATE DATALISTS ==========
    fetch('/api/product-names')
      .then(res => res.json())
      .then(names => {
        document.getElementById('product-names').innerHTML = names.map(n => `<option value="${n}">`).join('');
      });
    fetch('/api/categories')
      .then(res => res.json())
      .then(cats => {
        document.getElementById('category-list').innerHTML = cats.map(c => `<option value="${c}">`).join('');
      });
    fetch('/api/suppliers')
      .then(res => res.json())
      .then(sups => {
        document.getElementById('supplier-list').innerHTML = sups.map(s => `<option value="${s}">`).join('');
      });

    // ========== MODAL SIZE ROW LOGIC ==========
    let modalSizeIndex = 1;
    document.getElementById('add-modal-size-row').addEventListener('click', function() {
      const container = document.getElementById('modal-sizes-container');
      const newRow = document.createElement('div');
      newRow.className = 'row mb-2 modal-size-row';
      newRow.innerHTML = `
        <div class="col-md-5">
          <select class="form-control" name="sizes[${modalSizeIndex}][size]">
            <option value="">Select Size</option>
            <option value="S">S</option>
            <option value="M">M</option>
            <option value="L">L</option>
            <option value="XL">XL</option>
            <option value="2XL">2XL</option>
            <option value="3XL">3XL</option>
            <option value="4XL">4XL</option>
            <option value="5XL">5XL</option>
          </select>
        </div>
        <div class="col-md-5">
          <input type="number" class="form-control" name="sizes[${modalSizeIndex}][stock]" placeholder="Quantity">
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-danger remove-modal-size-row">Remove</button>
        </div>
      `;
      container.appendChild(newRow);
      updateModalRemoveButtons();
      modalSizeIndex++;
    });

    function updateModalRemoveButtons() {
      const rows = document.querySelectorAll('.modal-size-row');
      rows.forEach((row, idx) => {
        const btn = row.querySelector('.remove-modal-size-row');
        if (btn) btn.style.display = rows.length > 1 ? '' : 'none';
        btn && btn.addEventListener('click', function() {
          row.remove();
          updateModalRemoveButtons();
        });
      });
    }
    updateModalRemoveButtons();

    // ========== TOGGLE SIZES/SINGLE STOCK ==========
    document.getElementById('modal-hasSizes').addEventListener('change', function(e) {
      if (e.target.checked) {
        document.getElementById('modal-sizes-section').style.display = 'block';
        document.getElementById('modal-single-stock-section').style.display = 'none';
      } else {
        document.getElementById('modal-sizes-section').style.display = 'none';
        document.getElementById('modal-single-stock-section').style.display = 'block';
      }
    });

    // ========== AUTO-CALCULATE MARGIN & SELLING PRICE ==========
    function calculateModalPrices() {
      const cost = parseFloat(document.getElementById('modal-cost_price').value) || 0;
      const marginPercent = parseFloat(document.getElementById('modal-margin_percent').value) || 0;
      const marginAmount = cost * (marginPercent / 100);
      const sellingPrice = cost + marginAmount;
      document.getElementById('modal-margin_rs').value = marginAmount.toFixed(2);
      document.getElementById('modal-selling_price').value = sellingPrice.toFixed(2);
    }
    document.getElementById('modal-cost_price').addEventListener('input', calculateModalPrices);
    document.getElementById('modal-margin_percent').addEventListener('input', calculateModalPrices);
    calculateModalPrices();

    // ========== ADD PRODUCT FORM SUBMIT ==========
    document.getElementById('add-product-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      const form = e.target;
      const formData = new FormData(form);
      const data = {};

      // Validation
      const hasSizes = document.getElementById('modal-hasSizes').checked;
      if (hasSizes) {
        const sizeRows = document.querySelectorAll('.modal-size-row');
        let validVariantFound = false;
        sizeRows.forEach(row => {
          const sizeSelect = row.querySelector('select[name^="sizes"][name$="[size]"]');
          const stockInput = row.querySelector('input[name^="sizes"][name$="[stock]"]');
          if (sizeSelect && stockInput && sizeSelect.value && stockInput.value.trim() !== '') {
            validVariantFound = true;
          }
        });
        if (!validVariantFound) {
          showToast('Please add at least one size with stock.', 'warning');
          return;
        }
      } else {
        const stockInput = document.getElementById('modal-stock');
        if (!stockInput.value.trim()) {
          showToast('Please enter stock quantity.', 'warning');
          return;
        }
      }

      formData.forEach((value, key) => {
        if (key.startsWith('sizes[')) {
          const match = key.match(/sizes\[(\d+)\]\[(\w+)\]/);
          if (match) {
            const idx = match[1];
            const field = match[2];
            data.sizes = data.sizes || {};
            data.sizes[idx] = data.sizes[idx] || {};
            data.sizes[idx][field] = value;
          }
        } else {
          data[key] = value;
        }
      });
      if (data.sizes) {
        data.sizes = Object.values(data.sizes);
      }

      try {
        const res = await fetch('/products/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        if (res.ok) {
          const result = await res.json();
          if (result.success) {
            const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('addProductModal'));
            modal.hide();
            fetchProducts();
            form.reset();
            // Reset sizes container
            document.getElementById('modal-sizes-container').innerHTML = `<div class="row mb-2 modal-size-row">
              <div class="col-md-5">
                <select class="form-control" name="sizes[0][size]">
                  <option value="">Select Size</option>
                  <option value="S">S</option>
                  <option value="M">M</option>
                  <option value="L">L</option>
                  <option value="XL">XL</option>
                  <option value="2XL">2XL</option>
                  <option value="3XL">3XL</option>
                  <option value="4XL">4XL</option>
                  <option value="5XL">5XL</option>
                </select>
              </div>
              <div class="col-md-5">
                <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity">
              </div>
              <div class="col-md-2">
                <button type="button" class="btn btn-danger remove-modal-size-row" style="display:none;">Remove</button>
              </div>
            </div>`;
            modalSizeIndex = 1;
            updateModalRemoveButtons();
            showToast('Product added successfully!', 'success');
          } else {
            showToast('Error saving product', 'danger');
          }
        } else {
          const err = await res.json();
          showToast(err.error || 'Error saving product', 'danger');
        }
      } catch (err) {
        console.error(err);
        showToast('Network error', 'danger');
      }
    });

    // ========== FILTERING ==========
    let allProducts = [];

    async function fetchProducts() {
      try {
        const response = await fetch('/api/products?_=' + Date.now());
        if (!response.ok) throw new Error('Failed to fetch');
        allProducts = await response.json();
        populateCategoryDropdown();
        applyFilters();
      } catch (error) {
        console.error(error);
        document.getElementById('products-table-body').innerHTML = '<tr><td colspan="13" class="text-center text-danger">Error loading products</td></tr>';
        showToast('Error loading products', 'danger');
      }
    }

    function applyFilters() {
      const searchTerm = document.getElementById('search-input').value.toLowerCase().trim();
      const category = document.getElementById('category-filter').value;
      const size = document.getElementById('size-filter').value;

      const filtered = allProducts.filter(product => {
        const matchesSearch = searchTerm === '' ||
          product.name.toLowerCase().includes(searchTerm) ||
          product.product_code.toLowerCase().includes(searchTerm) ||
          product.category.toLowerCase().includes(searchTerm) ||
          product.supplier.toLowerCase().includes(searchTerm);

        const matchesCategory = category === '' || product.category === category;

        const matchesSize = size === '' ||
          (product.variants && product.variants.some(v => v.size === size));

        return matchesSearch && matchesCategory && matchesSize;
      });

      renderTable(filtered);
      updateTotals(filtered);
    }

    function getDateLabel(date) {
      const today = new Date();
      const yesterday = new Date(today);
      yesterday.setDate(yesterday.getDate() - 1);

      const inputDate = new Date(date);
      inputDate.setHours(0,0,0,0);
      today.setHours(0,0,0,0);
      yesterday.setHours(0,0,0,0);

      if (inputDate.getTime() === today.getTime()) return 'Today';
      if (inputDate.getTime() === yesterday.getTime()) return 'Yesterday';

      const diffDays = Math.round((today - inputDate) / (1000*60*60*24));
      if (diffDays <= 7) return 'This Week';
      if (diffDays <= 30) return 'This Month';
      return 'Older';
    }

    function renderTable(products) {
      const tbody = document.getElementById('products-table-body');
      if (products.length === 0) {
        tbody.innerHTML = '<tr><td colspan="13" class="text-center">No products match your filters.</td></tr>';
        return;
      }

      // Group products by date (YYYY-MM-DD)
      const groups = {};
      products.forEach(product => {
        const date = new Date(product.created_at);
        const dateKey = date.toISOString().split('T')[0];
        if (!groups[dateKey]) groups[dateKey] = [];
        groups[dateKey].push(product);
      });

      // Sort date keys descending (newest first)
      const sortedDates = Object.keys(groups).sort().reverse();

      let html = '';
      sortedDates.forEach(dateKey => {
        const dateProducts = groups[dateKey];
        const sampleDate = new Date(dateKey);
        const label = getDateLabel(sampleDate);
        const formattedDate = sampleDate.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });

        // Section header row
        html += `<tr class="table-secondary"><td colspan="13" style="font-weight: bold; background-color: #e9ecef;">${label} — ${formattedDate}</td></tr>`;

        dateProducts.forEach(product => {
          const createdDate = new Date(product.created_at);
          const today = new Date();
          const diffTime = today - createdDate;
          const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
          const ageDisplay = diffDays > 0 ? diffDays : 'Today';
          const addedOn = createdDate.toLocaleDateString();

          html += `
            <tr class="clickable-row" data-href="/products/${product.id}">
               <td>${product.product_code}</td>
               <td>${product.category}</td>
               <td>${product.name}</td>
               <td>${product.supplier}</td>
               <td>
                ${product.has_sizes
                  ? (product.variants && product.variants.length > 0
                      ? product.variants.map(v => `${v.size}: ${v.stock}`).join('<br>')
                      : '<span class="text-muted">—</span>')
                  : (product.variants && product.variants[0] ? `Stock: ${product.variants[0].stock}` : '<span class="text-muted">0</span>')}
               </td>
               <td>₹${product.cost_price}</td>
               <td>${product.margin_percent}%</td>
               <td>${product.margin_rs}</td>
               <td>₹${product.selling_price}</td>
               <td>${addedOn}</td>
               <td>${ageDisplay}</td>
               <td>
                <a href="/products/${product.id}">
                  <img src="/api/qr/${product.qr_code}" alt="QR" style="width: 50px; height: 50px;">
                </a>
               </td>
               <td>
                <a href="/products/${product.id}" class="btn btn-info btn-sm w-100">View</a>
               </td>
             </tr>
          `;
        });
      });

      tbody.innerHTML = html;
      document.getElementById('update-status').innerText = `Last updated: ${new Date().toLocaleTimeString()}`;

      // Make all clickable rows navigate to product detail
      document.querySelectorAll('.clickable-row').forEach(row => {
        row.addEventListener('click', function(e) {
          // Prevent navigation if clicking on an interactive element inside the row
          if (e.target.tagName === 'A' || e.target.tagName === 'IMG' || e.target.closest('a')) {
            return;
          }
          const href = this.getAttribute('data-href');
          if (href) window.location.href = href;
        });
      });
    }

    function updateTotals(products) {
      let totalCost = 0, totalSelling = 0;
      products.forEach(product => {
        const costPrice = parseFloat(product.cost_price) || 0;
        const sellingPrice = parseFloat(product.selling_price) || 0;
        if (product.variants && product.variants.length > 0) {
          product.variants.forEach(variant => {
            const stock = parseInt(variant.stock) || 0;
            totalCost += costPrice * stock;
            totalSelling += sellingPrice * stock;
          });
        }
      });
      document.getElementById('totalCostPrice').innerText = `₹${totalCost.toFixed(2)}`;
      document.getElementById('totalSellingPrice').innerText = `₹${totalSelling.toFixed(2)}`;
    }

    function populateCategoryDropdown() {
      const categories = [...new Set(allProducts.map(p => p.category))].sort();
      const select = document.getElementById('category-filter');
      select.innerHTML = '<option value="">All Categories</option>' +
        categories.map(cat => `<option value="${cat}">${cat}</option>`).join('');
    }

    // Event listeners for filters
    document.getElementById('search-input').addEventListener('input', applyFilters);
    document.getElementById('category-filter').addEventListener('change', applyFilters);
    document.getElementById('size-filter').addEventListener('change', applyFilters);
    document.getElementById('clear-filters').addEventListener('click', () => {
      document.getElementById('search-input').value = '';
      document.getElementById('category-filter').value = '';
      document.getElementById('size-filter').value = '';
      applyFilters();
    });

    // Initialisation
    document.addEventListener('DOMContentLoaded', function() {
      fetchProducts();
      const socket = io();
      socket.on('products-updated', fetchProducts);
      document.getElementById('refresh-now').addEventListener('click', fetchProducts);
    });
  </script>
</body>
</html>
