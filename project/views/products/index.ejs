<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .dashboard-title {
      font-weight: 700;
      color: #2563eb;
      letter-spacing: 1px;
      margin-bottom: 24px;
      text-align: center;
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-info {
      background: linear-gradient(90deg, #38bdf8 0%, #bae6fd 100%);
      border: none;
      color: #075985;
    }
    .btn-warning {
      background: linear-gradient(90deg, #f59e42 0%, #fef08a 100%);
      border: none;
      color: #92400e;
    }
    .table-striped > tbody > tr:nth-of-type(odd) {
      background-color: #f1f5f9;
    }
    .table th {
      background-color: #e0e7ef;
      color: #334155;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link" href="/sell">Sell</a></li>
          <li class="nav-item"><a class="nav-link disabled" href="#">Reports</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <div class="container mt-4">
    <h1 class="dashboard-title"><i class="fa-solid fa-boxes-stacked me-2"></i>Products Dashboard</h1>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a href="/products/add" class="btn btn-success">Add Product</a>
      <div>
        <span id="update-status" class="text-muted me-2"></span>
        <button id="refresh-now" class="btn btn-sm btn-outline-secondary">Refresh Now</button>
      </div>
    </div>
    <form id="bulk-delete-form" method="POST" action="/products/bulk-delete" onsubmit="return confirm('Are you sure you want to delete the selected products? This action cannot be undone.');">
      <div class="mb-2">
        <input type="checkbox" id="select-all"> <label for="select-all" class="ms-1">Select All</label>
      </div>
      <table class="table table-striped">
        <thead>
          <tr>
            <th></th>
            <th>Product Code</th>
            <th>Category</th>
            <th>Name</th>
            <th>Supplier</th>
            <th>Sizes & Stock</th>
            <th>Cost Price (₹)</th>
            <th>Margin (%)</th>
            <th>Margin (₹)</th>
            <th>Selling Price (₹)</th>
            <th>QR Code</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="products-table-body">
          <tr><td colspan="7" class="text-center">Loading...</td></tr>
        </tbody>
      </table>
      <button type="submit" class="btn btn-danger" id="bulk-delete-btn" disabled>Delete Selected</button>
    </form>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    // Function to fetch products and update the table
    // Store and restore selected product IDs to preserve selection across refreshes
    function getSelectedProductIds() {
      try {
        return JSON.parse(localStorage.getItem('selectedProductIds') || '[]');
      } catch { return []; }
    }
    function setSelectedProductIds(ids) {
      localStorage.setItem('selectedProductIds', JSON.stringify(ids));
    }

    async function fetchProducts() {
      try {
        const response = await fetch('/api/products?_=' + Date.now());
        if (!response.ok) throw new Error('Failed to fetch');
        const products = await response.json();

        const selectedIds = new Set(getSelectedProductIds());
        const tbody = document.getElementById('products-table-body');
        if (products.length === 0) {
          tbody.innerHTML = '<tr><td colspan="13" class="text-center">No products found.</td></tr>';
        } else {
          tbody.innerHTML = products.map(product => `
            <tr>
              <td><input type="checkbox" class="product-checkbox" name="productIds[]" value="${product.id}" ${selectedIds.has(product.id) ? 'checked' : ''}></td>
              <td>${product.product_code}</td>
              <td>${product.category}</td>
              <td>${product.name}</td>
              <td>${product.supplier}</td>
              <td>
                ${product.variants && product.variants.length > 0
                  ? product.variants.map(v => `${v.size}: ${v.stock}`).join('<br>')
                  : '<span class="text-muted">—</span>'}
              </td>
              <td>₹${product.cost_price}</td>
              <td>${product.margin_percent}%</td>
              <td>${product.margin_rs}</td>
              <td>₹${product.selling_price}</td>
              <td>
                <a href="/products/${product.id}">
                  <img src="/api/qr/${product.qr_code}" alt="QR" style="width: 50px; height: 50px;">
                </a>
              </td>
              <td>
                <a href="/products/${product.id}" class="btn btn-sm btn-info">View</a>
                <a href="/products/edit/${product.id}" class="btn btn-sm btn-warning">Edit</a>
                <form method="POST" action="/products/delete/${product.id}" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');">
                  <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          `).join('');
        }
    // Bulk select/deselect logic
    function updateBulkDeleteBtn() {
      const tbody = document.getElementById('products-table-body');
      const bulkDeleteBtn = document.getElementById('bulk-delete-btn');
      const checked = tbody.querySelectorAll('.product-checkbox:checked').length;
      bulkDeleteBtn.disabled = checked === 0;
    }
    function updateSelectAllCheckbox() {
      const tbody = document.getElementById('products-table-body');
      const selectAll = document.getElementById('select-all');
      const checkboxes = tbody.querySelectorAll('.product-checkbox');
      const checked = tbody.querySelectorAll('.product-checkbox:checked').length;
      selectAll.checked = checkboxes.length > 0 && checked === checkboxes.length;
      selectAll.indeterminate = checked > 0 && checked < checkboxes.length;
    }
    document.addEventListener('DOMContentLoaded', function() {
      const selectAll = document.getElementById('select-all');
      const tbody = document.getElementById('products-table-body');
      // Restore selection on page load
      setTimeout(() => {
        const selectedIds = new Set(getSelectedProductIds());
        tbody.querySelectorAll('.product-checkbox').forEach(cb => {
          cb.checked = selectedIds.has(cb.value) || selectedIds.has(Number(cb.value));
        });
        updateBulkDeleteBtn();
        updateSelectAllCheckbox();
      }, 100);
      selectAll.addEventListener('change', function() {
        const checkboxes = tbody.querySelectorAll('.product-checkbox');
        checkboxes.forEach(cb => { cb.checked = selectAll.checked; });
        // Save selected IDs
        const ids = Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
        setSelectedProductIds(ids);
        updateBulkDeleteBtn();
      });
      tbody.addEventListener('change', function(e) {
        if (e.target.classList.contains('product-checkbox')) {
          // Save selected IDs
          const checkboxes = tbody.querySelectorAll('.product-checkbox');
          const ids = Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
          setSelectedProductIds(ids);
          updateBulkDeleteBtn();
          updateSelectAllCheckbox();
        }
      });
    });
    // After table update, re-bind select all and update button, and restore selection
    function rebindBulkSelect() {
      updateBulkDeleteBtn();
      updateSelectAllCheckbox();
      const selectAll = document.getElementById('select-all');
      const tbody = document.getElementById('products-table-body');
      // Restore selection after table update
      const selectedIds = new Set(getSelectedProductIds());
      tbody.querySelectorAll('.product-checkbox').forEach(cb => {
        cb.checked = selectedIds.has(cb.value) || selectedIds.has(Number(cb.value));
      });
      selectAll.addEventListener('change', function() {
        const checkboxes = tbody.querySelectorAll('.product-checkbox');
        checkboxes.forEach(cb => { cb.checked = selectAll.checked; });
        // Save selected IDs
        const ids = Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
        setSelectedProductIds(ids);
        updateBulkDeleteBtn();
      });
      tbody.addEventListener('change', function(e) {
        if (e.target.classList.contains('product-checkbox')) {
          // Save selected IDs
          const checkboxes = tbody.querySelectorAll('.product-checkbox');
          const ids = Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
          setSelectedProductIds(ids);
          updateBulkDeleteBtn();
          updateSelectAllCheckbox();
        }
      });
    }
    // Call after fetchProducts updates table
    setTimeout(rebindBulkSelect, 0);
        document.getElementById('update-status').innerText = `Last updated: ${new Date().toLocaleTimeString()}`;
      } catch (error) {
        console.error(error);
        document.getElementById('products-table-body').innerHTML = '<tr><td colspan="6" class="text-center text-danger">Error loading products</td></tr>';
      }
    }

    // Initial load
    fetchProducts();

    // Real-time updates using Socket.IO
    const socket = io();
    socket.on('products-updated', () => {
      fetchProducts();
    });

    // Manual refresh button
    document.getElementById('refresh-now').addEventListener('click', fetchProducts);
  </script>
</body>
</html>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</html>