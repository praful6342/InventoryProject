<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Inventory Dashboard</title>
    <link rel="stylesheet" href="/public/styles.css">
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .dashboard-container { max-width: 1000px; margin: auto; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; }
        th { background: #f4f4f4; }
        .actions button { margin-right: 5px; }
        .search-bar { margin-bottom: 20px; }
    </style>
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
                    <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
                    <li class="nav-item"><a class="nav-link disabled" href="#">Reports</a></li>
                </ul>
            </div>
        </div>
    </nav>
<div class="dashboard-container">
    <h1>Inventory Dashboard</h1>
    <div class="search-bar">
        <form method="GET" action="/products/dashboard">
            <input type="text" name="search" placeholder="Search products...">
            <button type="submit">Search</button>
            <button type="button" id="add-inline-product">Add New Product</button>
        </form>
    </div>
    <table>
        <thead>
        <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Quantity</th>
            <th>Price</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        <% products.forEach(function(product) { %>
            <tr>
                <td><%= product.name %></td>
                <td><%= product.category %></td>
                <td><%= product.quantity %></td>
                <td><%= product.price %></td>
                <td class="actions">
                    <a href="/products/edit/<%= product._id %>"><button>Edit</button></a>
                    <form method="POST" action="/products/delete/<%= product._id %>" style="display:inline;">
                        <button type="submit" onclick="return confirm('Delete this product?')">Delete</button>
                    </form>
                </td>
            </tr>
        <% }); %>
        <!-- Inline Add Product Row (hidden by default) -->
        <tr id="inline-add-row" style="display:none; background:#e6f7ff;">
            <td><input type="text" id="inline-name" placeholder="Name" class="form-control"></td>
            <td><input type="text" id="inline-category" placeholder="Category" class="form-control"></td>
            <td><input type="number" id="inline-quantity" placeholder="Quantity" class="form-control"></td>
            <td><input type="number" id="inline-price" placeholder="Price" class="form-control"></td>
            <td class="actions">
                <button id="save-inline-product">Save</button>
                <button id="cancel-inline-product" type="button">Cancel</button>
            </td>
        </tr>
        </tbody>
    </table>
</div>
</body>

<script>
// Show inline add row
document.getElementById('add-inline-product').addEventListener('click', function() {
    document.getElementById('inline-add-row').style.display = '';
    this.disabled = true;
});

// Cancel inline add
document.getElementById('cancel-inline-product').addEventListener('click', function() {
    document.getElementById('inline-add-row').style.display = 'none';
    document.getElementById('add-inline-product').disabled = false;
    // Clear fields
    document.getElementById('inline-name').value = '';
    document.getElementById('inline-category').value = '';
    document.getElementById('inline-quantity').value = '';
    document.getElementById('inline-price').value = '';
});

// Save inline product via AJAX
document.getElementById('save-inline-product').addEventListener('click', function() {
    const name = document.getElementById('inline-name').value.trim();
    const category = document.getElementById('inline-category').value.trim();
    const quantity = document.getElementById('inline-quantity').value.trim();
    const price = document.getElementById('inline-price').value.trim();
    if (!name || !category || !quantity || !price) {
        alert('Please fill all fields');
        return;
    }
    fetch('/products/inline-add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, category, quantity, price })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error: ' + (data.error || 'Could not add product'));
        }
    })
    .catch(() => alert('Network error'));
});
</script>
</html>
