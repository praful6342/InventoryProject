<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload Stocks CSV</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-5">
    <h1 class="mb-4">Upload Stocks CSV</h1>
    <form action="/products/upload-csv" method="POST" enctype="multipart/form-data">
      <div class="mb-3">
        <label for="csvfile" class="form-label">Select CSV File</label>
        <input class="form-control" type="file" id="csvfile" name="csvfile" accept=".csv">
      </div>
      <button type="submit" class="btn btn-primary">Upload</button>
      <a href="/products" class="btn btn-secondary">Cancel</a>
    </form>
  </div>
</body>
</html>
