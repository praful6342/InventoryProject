<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit <%= product.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .edit-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-secondary {
      background: linear-gradient(90deg, #64748b 0%, #cbd5e1 100%);
      border: none;
      color: #1e293b;
    }
    .form-label {
      font-weight: 600;
      color: #2563eb;
    }
    .form-control {
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link" href="/sell">Sell</a></li>
          <li class="nav-item"><a class="nav-link disabled" href="#">Reports</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <div class="container mt-4">
    <h1 class="edit-title"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Product: <%= product.name %></h1>
    <form action="/products/update/<%= product.id %>" method="POST">
      <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <input type="text" class="form-control" id="category" name="category" value="<%= product.category %>">
      </div>
      <div class="mb-3">
        <label for="name" class="form-label">Product Name</label>
        <input type="text" class="form-control" id="name" name="name" value="<%= product.name %>">
      </div>
      <div class="mb-3">
        <label for="supplier" class="form-label">Supplier</label>
        <input type="text" class="form-control" id="supplier" name="supplier" value="<%= product.supplier %>">
      </div>
      <div class="mb-3">
        <label class="form-label">Sizes & Stock</label>
        <div id="sizes-container">
          <% if (product.variants && product.variants.length > 0) { %>
            <% product.variants.forEach(function(v, idx) { %>
              <div class="row mb-2 size-row">
                <div class="col-md-5">
                  <select class="form-control" name="sizes[<%= idx %>][size]">
                    <option value="">Select Size</option>
                    <option value="S" <%= v.size === 'S' ? 'selected' : '' %>>S</option>
                    <option value="M" <%= v.size === 'M' ? 'selected' : '' %>>M</option>
                    <option value="L" <%= v.size === 'L' ? 'selected' : '' %>>L</option>
                    <option value="XL" <%= v.size === 'XL' ? 'selected' : '' %>>XL</option>
                    <option value="XXL" <%= v.size === 'XXL' ? 'selected' : '' %>>XXL</option>
                  </select>
                </div>
                <div class="col-md-5">
                  <input type="number" class="form-control" name="sizes[<%= idx %>][stock]" value="<%= v.stock %>" placeholder="Quantity">
                </div>
                <div class="col-md-2">
                  <button type="button" class="btn btn-danger remove-size-row" <%= product.variants.length === 1 ? 'style="display:none;"' : '' %>>Remove</button>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="row mb-2 size-row">
              <div class="col-md-5">
                <select class="form-control" name="sizes[0][size]">
                  <option value="">Select Size</option>
                  <option value="S">S</option>
                  <option value="M">M</option>
                  <option value="L">L</option>
                  <option value="XL">XL</option>
                  <option value="XXL">XXL</option>
                </select>
              </div>
              <div class="col-md-5">
                <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity">
              </div>
              <div class="col-md-2">
                <button type="button" class="btn btn-danger remove-size-row" style="display:none;">Remove</button>
              </div>
            </div>
          <% } %>
        </div>
        <button type="button" class="btn btn-primary" id="add-size-row">Add Size</button>
      </div>
      <div class="mb-3">
        <label for="cost_price" class="form-label">Cost Price (₹)</label>
        <input type="number" step="0.01" class="form-control" id="cost_price" name="cost_price" value="<%= product.cost_price %>">
      </div>
      <div class="mb-3">
        <label for="margin_percent" class="form-label">Margin (%)</label>
        <input type="number" step="0.01" class="form-control" id="margin_percent" name="margin_percent" value="<%= product.margin_percent %>">
      </div>
      <div class="mb-3">
        <label for="margin_rs" class="form-label">Margin (₹)</label>
        <input type="number" step="0.01" class="form-control" id="margin_rs" name="margin_rs" value="<%= product.margin_rs %>">
      </div>
      <div class="mb-3">
        <label for="selling_price" class="form-label">Selling Price (₹)</label>
        <input type="number" step="0.01" class="form-control" id="selling_price" name="selling_price" value="<%= product.selling_price %>">
      </div>
      <button type="submit" class="btn btn-primary">Update Product</button>
      <a href="/products/<%= product.id %>" class="btn btn-secondary">Cancel</a>
    </form>
  </div>
  <script>
    let sizeIndex = parseInt('<%= product.variants && product.variants.length ? product.variants.length : 1 %>', 10);
    document.getElementById('add-size-row').addEventListener('click', function() {
      const container = document.getElementById('sizes-container');
      const newRow = document.createElement('div');
      newRow.className = 'row mb-2 size-row';
      newRow.innerHTML = `
        <div class="col-md-5">
          <select class="form-control" name="sizes[${sizeIndex}][size]">
            <option value="">Select Size</option>
            <option value="S">S</option>
            <option value="M">M</option>
            <option value="L">L</option>
            <option value="XL">XL</option>
            <option value="XXL">XXL</option>
          </select>
        </div>
        <div class="col-md-5">
          <input type="number" class="form-control" name="sizes[${sizeIndex}][stock]" placeholder="Quantity">
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-danger remove-size-row">Remove</button>
        </div>
      `;
      container.appendChild(newRow);
      updateRemoveButtons();
      sizeIndex++;
    });
    function updateRemoveButtons() {
      const rows = document.querySelectorAll('.size-row');
      rows.forEach((row, idx) => {
        const btn = row.querySelector('.remove-size-row');
        if (btn) btn.style.display = rows.length > 1 ? '' : 'none';
        btn && btn.addEventListener('click', function() {
          row.remove();
          updateRemoveButtons();
        });
      });
    }
    updateRemoveButtons();
  </script>
  </div>
</body>
</html>