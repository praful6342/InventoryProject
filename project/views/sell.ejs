<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Sale</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .sale-title {
      font-weight: 700;
      color: #22c55e;
      text-align: center;
      margin-bottom: 24px;
    }
    .btn-success {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      border: none;
      color: #065f46;
    }
    .btn-secondary {
      background: linear-gradient(90deg, #64748b 0%, #cbd5e1 100%);
      border: none;
      color: #1e293b;
    }
    .form-label {
      font-weight: 600;
      color: #2563eb;
    }
    .form-control {
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link" href="/sell">Sell</a></li>
          <li class="nav-item"><a class="nav-link disabled" href="#">Reports</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <div class="container mt-4">
    <h1 class="sale-title"><i class="fa-solid fa-cart-plus me-2"></i>New Sale</h1>
    <% if (product) { %>
      <div class="alert alert-success">Selling: <strong><%= product.name %></strong> (<%= product.category %>) - ₹<%= product.selling_price %></div>
      <form action="/sell/add" method="POST" class="mb-4 mt-3">
        <input type="hidden" name="product_id" value="<%= product.id %>">
        <div class="mb-3">
          <label for="size" class="form-label">Select Size</label>
          <select class="form-control" id="size" name="size" required>
            <option value="">Select Size</option>
            <% variants.forEach(function(v) { %>
              <option value="<%= v.size %>"><%= v.size %> (Stock: <%= v.stock %>)</option>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label for="quantity" class="form-label">Quantity</label>
          <input type="number" class="form-control" id="quantity" name="quantity" min="1" value="1" required>
        </div>
        <button type="submit" class="btn btn-success">Add to Cart</button>
        <a href="/sell" class="btn btn-secondary ms-2">View Cart / Checkout</a>
      </form>
      <a href="/scan" class="btn btn-primary">Scan Another Product</a>
    <% } else if (cart && cart.length) { %>
      <div class="alert alert-info">Cart contains <strong><%= cart.length %></strong> product(s):</div>
      <table class="table table-bordered mt-3">
        <thead>
          <tr>
            <th>Name</th>
            <th>Category</th>
            <th>Size</th>
            <th>Quantity</th>
            <th>Unit Price</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          <% let total = 0; cart.forEach(function(item) { total += item.selling_price * item.quantity; %>
            <tr>
              <td><%= item.name %></td>
              <td><%= item.category %></td>
              <td><%= item.size %></td>
              <td><%= item.quantity %></td>
              <td>₹<%= item.selling_price %></td>
              <td>₹<%= (item.selling_price * item.quantity).toFixed(2) %></td>
            </tr>
          <% }); %>
          <tr class="table-success">
            <td colspan="5" class="text-end"><strong>Grand Total</strong></td>
            <td><strong>₹<%= total.toFixed(2) %></strong></td>
          </tr>
        </tbody>
      </table>
      <form action="/sell/complete" method="POST" class="mt-4">
        <div class="mb-3">
          <label for="customer_name" class="form-label">Customer Name (optional)</label>
          <input type="text" class="form-control" id="customer_name" name="customer_name">
        </div>
        <div class="mb-3">
          <label for="customer_phone" class="form-label">Customer Phone (optional)</label>
          <input type="text" class="form-control" id="customer_phone" name="customer_phone">
        </div>
        <button type="submit" class="btn btn-success">Complete Sale & Print Bill</button>
        <a href="/scan" class="btn btn-primary ms-2">Add More Products</a>
      </form>
    <% } else { %>
      <div class="alert alert-info">Sales can only be completed by scanning the product QR code. Manual selection is disabled.</div>
      <a href="/scan" class="btn btn-primary mt-3">Go to QR Scan</a>
    <% } %>
  </div>

  <script>
    // Optional: Update max quantity based on selected product's stock
    document.getElementById('product_id').addEventListener('change', function() {
      const selected = this.options[this.selectedIndex];
      const stockText = selected.text.match(/Stock: (\d+)/);
      if (stockText) {
        const stock = parseInt(stockText[1]);
        document.getElementById('quantity').max = stock;
      }
    });
  </script>
</body>
</html>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</html>