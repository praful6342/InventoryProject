<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Sale</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .sale-title {
      font-weight: 700;
      color: #22c55e;
      text-align: center;
      margin-bottom: 24px;
    }
    .btn-success {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      border: none;
      color: #065f46;
    }
    .btn-secondary {
      background: linear-gradient(90deg, #64748b 0%, #cbd5e1 100%);
      border: none;
      color: #1e293b;
    }
    .form-label {
      font-weight: 600;
      color: #2563eb;
    }
    .form-control {
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link" href="/sell">Sell</a></li>
          <li class="nav-item"><a class="nav-link disabled" href="#">Reports</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <div class="container mt-4">
    <h1 class="sale-title"><i class="fa-solid fa-cart-plus me-2"></i>New Sale</h1>
    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form action="/sell" method="POST">
      <div class="mb-3">
        <label for="product_id" class="form-label">Select Product</label>
        <select class="form-select" id="product_id" name="product_id" required>
          <option value="">-- Choose product --</option>
          <% products.forEach(p => { %>
            <option value="<%= p.id %>" <%= product && product.id == p.id ? 'selected' : '' %>>
              <%= p.name %> - ₹<%= p.selling_price %> (Stock: <%= p.stock %>)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label for="quantity" class="form-label">Quantity</label>
        <input type="number" class="form-control" id="quantity" name="quantity" min="1" required>
      </div>

      <h4 class="mt-4">Customer Details (optional)</h4>
      <div class="mb-3">
        <label for="customer_name" class="form-label">Name</label>
        <input type="text" class="form-control" id="customer_name" name="customer_name">
      </div>
      <div class="mb-3">
        <label for="customer_phone" class="form-label">Phone</label>
        <input type="tel" class="form-control" id="customer_phone" name="customer_phone">
      </div>
      <div class="mb-3">
        <label for="customer_email" class="form-label">Email</label>
        <input type="email" class="form-control" id="customer_email" name="customer_email">
      </div>

      <button type="submit" class="btn btn-success">Complete Sale</button>
      <a href="/" class="btn btn-secondary">Cancel</a>
    </form>
  </div>

  <script>
    // Optional: Update max quantity based on selected product's stock
    document.getElementById('product_id').addEventListener('change', function() {
      const selected = this.options[this.selectedIndex];
      const stockText = selected.text.match(/Stock: (\d+)/);
      if (stockText) {
        const stock = parseInt(stockText[1]);
        document.getElementById('quantity').max = stock;
      }
    });
  </script>
</body>
</html>