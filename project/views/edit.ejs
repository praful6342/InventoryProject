<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit <%= product.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .edit-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-secondary {
      background: linear-gradient(90deg, #64748b 0%, #cbd5e1 100%);
      border: none;
      color: #1e293b;
    }
    .form-label {
      font-weight: 600;
      color: #2563eb;
    }
    .form-control {
      border-radius: 8px;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { currentPage: 'edit' }) %>

  <div class="container mt-4">
    <h1 class="edit-title"><i class="fa-solid fa-pen-to-square me-2"></i>Edit Product: <%= product.name %></h1>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fa-solid fa-circle-exclamation me-2"></i><%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <form action="/products/update/<%= product.id %>" method="POST">
      <!-- Category with datalist -->
      <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <input type="text" class="form-control" id="category" name="category" value="<%= product.category %>" list="category-list" autocomplete="off">
        <datalist id="category-list"></datalist>
      </div>
      <!-- Name with datalist -->
      <div class="mb-3">
        <label for="name" class="form-label">Product Name</label>
        <input type="text" class="form-control" id="name" name="name" value="<%= product.name %>" list="product-names" autocomplete="off">
        <datalist id="product-names"></datalist>
      </div>
      <!-- Supplier with datalist -->
      <div class="mb-3">
        <label for="supplier" class="form-label">Supplier</label>
        <input type="text" class="form-control" id="supplier" name="supplier" value="<%= product.supplier %>" list="supplier-list" autocomplete="off">
        <datalist id="supplier-list"></datalist>
      </div>

      <!-- Created At (manual date) -->
      <div class="mb-3">
        <label for="created_at" class="form-label">Added On (optional)</label>
        <input type="date" class="form-control" id="created_at" name="created_at" value="<%= product.created_at ? new Date(product.created_at).toISOString().split('T')[0] : '' %>" autocomplete="off">
        <small class="text-muted">Leave blank to keep existing date</small>
      </div>

      <div class="mb-3 form-check">
        <input type="checkbox" class="form-check-input" id="hasSizes" name="has_sizes" value="on" <%= product.has_sizes ? 'checked' : '' %>>
        <label class="form-check-label" for="hasSizes">This product has sizes (S, M, L, XL, 2XL, 3XL, 4XL, 5XL)</label>
      </div>

      <!-- Sizes Section -->
      <div id="sizes-section" class="mb-3" style="display: <%= product.has_sizes ? 'block' : 'none' %>;">
        <label class="form-label">Sizes & Stock</label>
        <div id="sizes-container">
          <% if (product.has_sizes && product.variants && product.variants.length > 0) { %>
            <% product.variants.forEach(function(v, idx) { %>
              <% if (v.size !== 'ONESIZE') { %>
              <div class="row mb-2 size-row">
                <div class="col-md-5">
                  <select class="form-control" name="sizes[<%= idx %>][size]">
                    <option value="">Select Size</option>
                    <option value="S" <%= v.size === 'S' ? 'selected' : '' %>>S</option>
                    <option value="M" <%= v.size === 'M' ? 'selected' : '' %>>M</option>
                    <option value="L" <%= v.size === 'L' ? 'selected' : '' %>>L</option>
                    <option value="XL" <%= v.size === 'XL' ? 'selected' : '' %>>XL</option>
                    <option value="2XL" <%= v.size === '2XL' ? 'selected' : '' %>>2XL</option>
                    <option value="3XL" <%= v.size === '3XL' ? 'selected' : '' %>>3XL</option>
                    <option value="4XL" <%= v.size === '4XL' ? 'selected' : '' %>>4XL</option>
                    <option value="5XL" <%= v.size === '5XL' ? 'selected' : '' %>>5XL</option>
                  </select>
                </div>
                <div class="col-md-5">
                  <input type="number" class="form-control" name="sizes[<%= idx %>][stock]" value="<%= v.stock %>" placeholder="Quantity" autocomplete="off">
                </div>
                <div class="col-md-2">
                  <button type="button" class="btn btn-danger remove-size-row" <%= product.variants.length === 1 ? 'style="display:none;"' : '' %>>Remove</button>
                </div>
              </div>
              <% } %>
            <% }); %>
          <% } else { %>
            <div class="row mb-2 size-row">
              <div class="col-md-5">
                <select class="form-control" name="sizes[0][size]">
                  <option value="">Select Size</option>
                  <option value="S">S</option>
                  <option value="M">M</option>
                  <option value="L">L</option>
                  <option value="XL">XL</option>
                  <option value="2XL">2XL</option>
                  <option value="3XL">3XL</option>
                  <option value="4XL">4XL</option>
                  <option value="5XL">5XL</option>
                </select>
              </div>
              <div class="col-md-5">
                <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity" autocomplete="off">
              </div>
              <div class="col-md-2">
                <button type="button" class="btn btn-danger remove-size-row" style="display:none;">Remove</button>
              </div>
            </div>
          <% } %>
        </div>
        <button type="button" class="btn btn-primary" id="add-size-row">Add Size</button>
      </div>

      <!-- Single Stock Section -->
      <div id="single-stock-section" class="mb-3" style="display: <%= product.has_sizes ? 'none' : 'block' %>;">
        <label for="stock" class="form-label">Stock (units)</label>
        <input type="number" class="form-control" id="stock" name="stock" min="0" value="<%= !product.has_sizes && product.variants && product.variants[0] ? product.variants[0].stock : '' %>" autocomplete="off">
      </div>

      <!-- Price Fields -->
      <div class="mb-3">
        <label for="cost_price" class="form-label">Cost Price (₹)</label>
        <input type="number" step="0.01" class="form-control" id="cost_price" name="cost_price" value="<%= product.cost_price %>" autocomplete="off">
      </div>
      <div class="mb-3">
        <label for="margin_percent" class="form-label">Margin (%)</label>
        <input type="number" step="0.01" class="form-control" id="margin_percent" name="margin_percent" value="<%= product.margin_percent %>" autocomplete="off">
      </div>
      <div class="mb-3">
        <label for="margin_rs" class="form-label">Margin (₹)</label>
        <input type="number" step="0.01" class="form-control" id="margin_rs" name="margin_rs" value="<%= product.margin_rs %>" readonly autocomplete="off">
      </div>
      <div class="mb-3">
        <label for="selling_price" class="form-label">Selling Price (₹)</label>
        <input type="number" step="0.01" class="form-control" id="selling_price" name="selling_price" value="<%= product.selling_price %>" readonly autocomplete="off">
      </div>

      <button type="submit" class="btn btn-primary">Update Product</button>
      <a href="/products/<%= product.id %>" class="btn btn-secondary">Cancel</a>
    </form>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Populate datalists
    fetch('/api/product-names')
      .then(res => res.json())
      .then(names => {
        document.getElementById('product-names').innerHTML = names.map(n => `<option value="${n}">`).join('');
      });
    fetch('/api/categories')
      .then(res => res.json())
      .then(cats => {
        document.getElementById('category-list').innerHTML = cats.map(c => `<option value="${c}">`).join('');
      });
    fetch('/api/suppliers')
      .then(res => res.json())
      .then(sups => {
        document.getElementById('supplier-list').innerHTML = sups.map(s => `<option value="${s}">`).join('');
      });

    let sizeIndex = parseInt('<%= product.variants && product.variants.length ? product.variants.length : 1 %>', 10);
    document.getElementById('add-size-row').addEventListener('click', function() {
      const container = document.getElementById('sizes-container');
      const newRow = document.createElement('div');
      newRow.className = 'row mb-2 size-row';
      newRow.innerHTML = `
        <div class="col-md-5">
          <select class="form-control" name="sizes[${sizeIndex}][size]">
            <option value="">Select Size</option>
            <option value="S">S</option>
            <option value="M">M</option>
            <option value="L">L</option>
            <option value="XL">XL</option>
            <option value="2XL">2XL</option>
            <option value="3XL">3XL</option>
            <option value="4XL">4XL</option>
            <option value="5XL">5XL</option>
          </select>
        </div>
        <div class="col-md-5">
          <input type="number" class="form-control" name="sizes[${sizeIndex}][stock]" placeholder="Quantity" autocomplete="off">
        </div>
        <div class="col-md-2">
          <button type="button" class="btn btn-danger remove-size-row">Remove</button>
        </div>
      `;
      container.appendChild(newRow);
      updateRemoveButtons();
      sizeIndex++;
    });

    function updateRemoveButtons() {
      const rows = document.querySelectorAll('.size-row');
      rows.forEach((row, idx) => {
        const btn = row.querySelector('.remove-size-row');
        if (btn) btn.style.display = rows.length > 1 ? '' : 'none';
        btn && btn.addEventListener('click', function() {
          row.remove();
          updateRemoveButtons();
        });
      });
    }
    updateRemoveButtons();

    // Toggle sizes/stock
    document.getElementById('hasSizes').addEventListener('change', function(e) {
      if (e.target.checked) {
        document.getElementById('sizes-section').style.display = 'block';
        document.getElementById('single-stock-section').style.display = 'none';
      } else {
        document.getElementById('sizes-section').style.display = 'none';
        document.getElementById('single-stock-section').style.display = 'block';
      }
    });

    // Auto-calculate margin and selling price
    function calculatePrices() {
      const cost = parseFloat(document.getElementById('cost_price').value) || 0;
      const marginPercent = parseFloat(document.getElementById('margin_percent').value) || 0;
      const marginAmount = cost * (marginPercent / 100);
      const sellingPrice = cost + marginAmount;
      document.getElementById('margin_rs').value = marginAmount.toFixed(2);
      document.getElementById('selling_price').value = sellingPrice.toFixed(2);
    }
    document.getElementById('cost_price').addEventListener('input', calculatePrices);
    document.getElementById('margin_percent').addEventListener('input', calculatePrices);
    calculatePrices();
  </script>
</body>
</html>
