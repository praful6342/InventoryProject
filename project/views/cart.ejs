<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopping Cart</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    .cart-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .cart-table {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .cart-table th {
      background-color: #e0e7ef;
      color: #334155;
      font-weight: 600;
    }
    .quantity-input {
      width: 80px;
      text-align: center;
    }
    .total-row {
      font-size: 1.2rem;
      font-weight: bold;
      background-color: #f1f5f9;
    }
    .btn-checkout {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      color: #065f46;
      border: none;
      font-weight: 600;
    }
    .empty-cart {
      text-align: center;
      padding: 40px;
      background: white;
      border-radius: 16px;
    }
    .cart-item-remove {
      opacity: 0;
      transition: opacity 0.3s ease;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { currentPage: 'cart' }) %>

  <div class="container mt-4">
    <h1 class="cart-title"><i class="fa-solid fa-cart-shopping me-2"></i>Shopping Cart</h1>

    <% if (!cart || cart.length === 0) { %>
      <div class="empty-cart">
        <i class="fa-solid fa-cart-shopping fa-4x text-muted mb-3"></i>
        <h3>Your cart is empty</h3>
        <p>Scan a product QR code to add items.</p>
        <a href="/scan" class="btn btn-primary">Go to Scanner</a>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% let grandTotal = 0; %>
        <% cart.forEach(item => { %>
          <% const itemTotal = item.selling_price * item.quantity; %>
          <% grandTotal += itemTotal; %>
          <div class="col-12 col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
              <div class="card-body d-flex flex-column justify-content-between">
                <div>
                  <h5 class="card-title mb-2 text-primary"><%= item.name %></h5>
                  <div class="mb-1 small text-muted">Code: <%= item.product_code %></div>
                  <div class="mb-1">Size: <span class="fw-semibold"><%= item.size %></span></div>
                  <div class="mb-1">Price: <span class="fw-semibold">₹<%= item.selling_price.toFixed(2) %></span></div>
                  <div class="mb-2">Total: <span class="fw-semibold text-success">₹<%= itemTotal.toFixed(2) %></span></div>
                </div>
                <div class="d-flex align-items-center gap-2 mt-2">
                  <input type="number" class="form-control quantity-input flex-shrink-1" value="<%= item.quantity %>" min="1" max="<%= item.maxStock %>" data-product-id="<%= item.productId %>" data-size="<%= item.size %>" style="max-width:90px;">
                  <button class="btn btn-danger btn-sm flex-grow-1 remove-item" data-product-id="<%= item.productId %>" data-size="<%= item.size %>"><i class="fa-solid fa-trash"></i> Remove</button>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="row mt-4">
        <div class="col-12 col-md-6 col-lg-4 ms-auto">
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <h5 class="card-title">Cart Summary</h5>
              <div class="d-flex justify-content-between mb-2">
                <span class="fw-semibold">Grand Total:</span>
                <span id="grandTotal" class="fw-bold text-success">₹<%= grandTotal.toFixed(2) %></span>
              </div>
              <div class="d-flex gap-2 mt-3">
                <a href="/scan" class="btn btn-primary w-50"><i class="fa-solid fa-qrcode"></i> Scan More</a>
                <a href="/sale/checkout" class="btn btn-checkout w-50"><i class="fa-solid fa-credit-card"></i> Checkout</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="d-flex justify-content-between mt-4">
        <a href="/scan" class="btn btn-primary"><i class="fa-solid fa-qrcode"></i> Continue Scanning</a>
        <a href="/sale/checkout" class="btn btn-checkout btn-lg"><i class="fa-solid fa-credit-card"></i> Proceed to Checkout</a>
      </div>
    <% } %>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Handle quantity change
    document.querySelectorAll('.quantity-input').forEach(input => {
      input.addEventListener('change', function() {
        const productId = this.dataset.productId;
        const size = this.dataset.size;
        const newQty = parseInt(this.value);
        if (newQty < 1) {
          this.value = 1;
          updateQuantity(productId, size, 1);
        } else {
          updateQuantity(productId, size, newQty);
        }
      });
    });

    // Handle remove with animation
    document.querySelectorAll('.remove-item').forEach(btn => {
      btn.addEventListener('click', function() {
        const productId = this.dataset.productId;
        const size = this.dataset.size;
        setTimeout(() => {
          updateQuantity(productId, size, 0);
        }, 300);
      });
    });

    function updateQuantity(productId, size, quantity) {
      fetch('/sale/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, size, quantity })
      })
      .then(res => res.json())
      .then(data => {
        if (data.error) {
          showToast(data.error, 'danger');
          location.reload();
        } else {
          location.reload();
        }
      })
      .catch(err => {
        console.error(err);
        showToast('Network error', 'danger');
      });
    }
  </script>
</body>
</html>
