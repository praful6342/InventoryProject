<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shopping Cart</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    .cart-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .cart-table {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .cart-table th {
      background-color: #e0e7ef;
      color: #334155;
      font-weight: 600;
    }
    .quantity-input {
      width: 80px;
      text-align: center;
    }
    .total-row {
      font-size: 1.2rem;
      font-weight: bold;
      background-color: #f1f5f9;
    }
    .btn-checkout {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      color: #065f46;
      border: none;
      font-weight: 600;
    }
    .empty-cart {
      text-align: center;
      padding: 40px;
      background: white;
      border-radius: 16px;
    }
    .cart-item-remove {
      opacity: 0;
      transition: opacity 0.3s ease;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <ul class="navbar-nav d-flex flex-row flex-wrap w-100 justify-content-end">
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link active" href="/sale/cart">Cart</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h1 class="cart-title"><i class="fa-solid fa-cart-shopping me-2"></i>Shopping Cart</h1>

    <% if (!cart || cart.length === 0) { %>
      <div class="empty-cart">
        <i class="fa-solid fa-cart-shopping fa-4x text-muted mb-3"></i>
        <h3>Your cart is empty</h3>
        <p>Scan a product QR code to add items.</p>
        <a href="/scan" class="btn btn-primary">Go to Scanner</a>
      </div>
    <% } else { %>
      <div class="table-responsive-sm table-responsive-md table-responsive-lg cart-table">
        <table class="table table-striped align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Product</th>
              <th>Code</th>
              <th>Size</th>
              <th>Price (₹)</th>
              <th>Quantity</th>
              <th>Total (₹)</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% let grandTotal = 0; %>
            <% cart.forEach(item => { %>
              <% const itemTotal = item.selling_price * item.quantity; %>
              <% grandTotal += itemTotal; %>
              <tr data-product-id="<%= item.productId %>" data-size="<%= item.size %>">
                <td><%= item.name %></td>
                <td><%= item.product_code %></td>
                <td><%= item.size %></td>
                <td>₹<%= item.selling_price.toFixed(2) %></td>
                <td>
                  <input type="number" class="form-control quantity-input" value="<%= item.quantity %>" min="1" max="<%= item.maxStock %>" data-product-id="<%= item.productId %>" data-size="<%= item.size %>">
                </td>
                <td class="item-total">₹<%= itemTotal.toFixed(2) %></td>
                <td>
                  <button class="btn btn-danger btn-sm w-100 mb-1 remove-item" data-product-id="<%= item.productId %>" data-size="<%= item.size %>">
                    <i class="fa-solid fa-trash"></i> Remove
                  </button>
                </td>
              </tr>
            <% }); %>
          </tbody>
          <tfoot>
            <tr class="total-row">
              <td colspan="6" class="text-end">Grand Total:</td>
              <td id="grandTotal">₹<%= grandTotal.toFixed(2) %></td>
              <td></td>
            </tr>
          </tfoot>
        </table>
      </div>

      <div class="d-flex justify-content-between mt-4">
        <a href="/scan" class="btn btn-primary"><i class="fa-solid fa-qrcode"></i> Continue Scanning</a>
        <a href="/sale/checkout" class="btn btn-checkout btn-lg"><i class="fa-solid fa-credit-card"></i> Proceed to Checkout</a>
      </div>
    <% } %>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Handle quantity change
    document.querySelectorAll('.quantity-input').forEach(input => {
      input.addEventListener('change', function() {
        const productId = this.dataset.productId;
        const size = this.dataset.size;
        const newQty = parseInt(this.value);
        if (newQty < 1) {
          this.value = 1;
          updateQuantity(productId, size, 1);
        } else {
          updateQuantity(productId, size, newQty);
        }
      });
    });

    // Handle remove with animation
    document.querySelectorAll('.remove-item').forEach(btn => {
      btn.addEventListener('click', function() {
        const productId = this.dataset.productId;
        const size = this.dataset.size;
        const row = this.closest('tr');
        row.classList.add('cart-item-remove');
        setTimeout(() => {
          updateQuantity(productId, size, 0);
        }, 300);
      });
    });

    function updateQuantity(productId, size, quantity) {
      fetch('/sale/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, size, quantity })
      })
      .then(res => res.json())
      .then(data => {
        if (data.error) {
          showToast(data.error, 'danger');
          location.reload();
        } else {
          location.reload();
        }
      })
      .catch(err => {
        console.error(err);
        showToast('Network error', 'danger');
      });
    }
  </script>
</body>
</html>