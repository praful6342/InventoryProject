<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Product</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .add-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .btn-success {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      border: none;
      color: #065f46;
    }
    .btn-secondary {
      background: linear-gradient(90deg, #64748b 0%, #cbd5e1 100%);
      border: none;
      color: #1e293b;
    }
    .form-label {
      font-weight: 600;
      color: #2563eb;
    }
    .form-control {
      border-radius: 8px;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar (Products active) -->
  <nav class="navbar navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <ul class="navbar-nav d-flex flex-row flex-wrap w-100 justify-content-end">
          <li class="nav-item"><a class="nav-link active" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link" href="/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/sale/cart">Cart</a></li>
        </ul>
      </div>
    </div>
  </nav>
  
  <div class="container mt-4">
    <h1 class="add-title"><i class="fa-solid fa-plus me-2"></i>Add New Product</h1>
    <form action="/products/add" method="POST">
      <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <input type="text" class="form-control" id="category" name="category">
      </div>
      <div class="mb-3">
        <label for="name" class="form-label">Product Name</label>
        <input type="text" class="form-control" id="name" name="name">
      </div>
        <div class="mb-3">
          <label for="supplier" class="form-label">Supplier</label>
          <input type="text" class="form-control" id="supplier" name="supplier" required>
        </div>
        <div class="mb-3 form-check">
          <input type="checkbox" class="form-check-input" id="hasSizes" name="has_sizes" value="on" checked>
          <label class="form-check-label" for="hasSizes">This product has sizes (e.g., S, M, L, XL, XXL)</label>
        </div>
        <div id="sizes-section" class="mb-3">
          <label class="form-label">Sizes & Stock</label>
          <div id="sizes-container">
            <div class="row mb-2 size-row">
              <div class="col-md-5">
                <select class="form-control" name="sizes[0][size]">
                  <option value="">Select Size</option>
                  <option value="S">S</option>
                  <option value="M">M</option>
                  <option value="L">L</option>
                  <option value="XL">XL</option>
                  <option value="XXL">XXL</option>
                </select>
              </div>
              <div class="col-md-5">
                <input type="number" class="form-control" name="sizes[0][stock]" placeholder="Quantity">
              </div>
              <div class="col-md-2">
                <button type="button" class="btn btn-danger remove-size-row" style="display:none;">Remove</button>
              </div>
            </div>
          </div>
          <button type="button" class="btn btn-primary" id="add-size-row">Add Size</button>
        </div>
        <div id="single-stock-section" class="mb-3" style="display: none;">
          <label for="stock" class="form-label">Stock (units)</label>
          <input type="number" class="form-control" id="stock" name="stock" min="0">
        </div>
      // ...existing code...
      <div class="mb-3">
        <label for="cost_price" class="form-label">Cost Price (₹)</label>
        <input type="number" step="0.01" class="form-control" id="cost_price" name="cost_price">
      </div>
      <div class="mb-3">
        <label for="margin_percent" class="form-label">Margin (%)</label>
        <input type="number" step="0.01" class="form-control" id="margin_percent" name="margin_percent">
      </div>
      <div class="mb-3">
        <label for="margin_rs" class="form-label">Margin (₹)</label>
        <input type="number" step="0.01" class="form-control" id="margin_rs" name="margin_rs" readonly>
      </div>
      <div class="mb-3">
        <label for="selling_price" class="form-label">Selling Price (₹)</label>
        <input type="number" step="0.01" class="form-control" id="selling_price" name="selling_price" readonly>
      </div>
      <button type="submit" class="btn btn-success">Save Product</button>
      <a href="/products" class="btn btn-secondary">Cancel</a>
    </form>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
      <script>
        let sizeIndex = 1;
        document.getElementById('add-size-row').addEventListener('click', function() {
          const container = document.getElementById('sizes-container');
          const newRow = document.createElement('div');
          newRow.className = 'row mb-2 size-row';
          newRow.innerHTML = `
            <div class="col-md-5">
              <select class="form-control" name="sizes[${sizeIndex}][size]">
                <option value="">Select Size</option>
                <option value="S">S</option>
                <option value="M">M</option>
                <option value="L">L</option>
                <option value="XL">XL</option>
                <option value="XXL">XXL</option>
              </select>
            </div>
            <div class="col-md-5">
              <input type="number" class="form-control" name="sizes[${sizeIndex}][stock]" placeholder="Quantity">
            </div>
            <div class="col-md-2">
              <button type="button" class="btn btn-danger remove-size-row">Remove</button>
            </div>
          `;
          container.appendChild(newRow);
          updateRemoveButtons();
          sizeIndex++;
        });
        function updateRemoveButtons() {
          const rows = document.querySelectorAll('.size-row');
          rows.forEach((row, idx) => {
            const btn = row.querySelector('.remove-size-row');
            if (btn) btn.style.display = rows.length > 1 ? '' : 'none';
            btn && btn.addEventListener('click', function() {
              row.remove();
              updateRemoveButtons();
            });
          });
        }
        updateRemoveButtons();

        // Toggle sizes/stock section
        document.getElementById('hasSizes').addEventListener('change', function(e) {
          if (e.target.checked) {
            document.getElementById('sizes-section').style.display = 'block';
            document.getElementById('single-stock-section').style.display = 'none';
          } else {
            document.getElementById('sizes-section').style.display = 'none';
            document.getElementById('single-stock-section').style.display = 'block';
          }
        });

        // Auto-calculate margin and selling price
        function calculatePrices() {
          const costInput = document.getElementById('cost_price');
          const marginPercentInput = document.getElementById('margin_percent');
          const marginRsInput = document.getElementById('margin_rs');
          const sellingPriceInput = document.getElementById('selling_price');

          const cost = parseFloat(costInput.value) || 0;
          const marginPercent = parseFloat(marginPercentInput.value) || 0;

          const marginAmount = cost * (marginPercent / 100);
          const sellingPrice = cost + marginAmount;

          marginRsInput.value = marginAmount.toFixed(2);
          sellingPriceInput.value = sellingPrice.toFixed(2);
        }

        document.getElementById('cost_price').addEventListener('input', calculatePrices);
        document.getElementById('margin_percent').addEventListener('input', calculatePrices);
        calculatePrices();
      </script>
</body>
</html>