<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Product Code Label</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Arial', 'Helvetica', sans-serif;
      background: #f5f5f5;
      margin: 0;
      padding: 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    h1 {
      margin-bottom: 20px;
      color: #333;
    }

    .preview-container {
      display: flex;
      flex-direction: column;
      gap: 15px;
      max-width: 800px;
      margin: 0 auto 100px;
      align-items: center;
    }

    .label-preview {
      width: 200px;
      height: 200px;
      background: white;
      border: 1px solid #bbb;
      border-radius: 0;
      box-shadow: none;
      padding: 0;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-family: 'Times New Roman', serif;
      font-weight: bold;
    }

    .product-code {
      font-size: 18px;
      font-family: 'Times New Roman', serif;
      font-weight: bold;
      color: #1e293b;
      word-break: break-all;
      background: #e0e7ff;
      padding: 6px 10px;
      border-radius: 6px;
      border-left: 3px solid #2563eb;
      margin-bottom: 8px;
    }

    .qr-section {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 5px;
    }

    .qr-image {
      width: 100px;
      height: 100px;
      border: 2px solid #2563eb;
      border-radius: 8px;
      background: white;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 6px;
    }

    .qr-image img {
      width: 90px;
      height: 90px;
      object-fit: contain;
    }

    .price {
      font-size: 16px;
      font-family: 'Times New Roman', serif;
      font-weight: bold;
      color: #000;
    }

    .download-controls {
      position: fixed;
      bottom: 20px;
      left: 0;
      right: 0;
      background: white;
      padding: 20px;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
      display: flex;
      gap: 20px;
      justify-content: center;
      align-items: center;
      z-index: 1000;
      border-top: 2px solid #2563eb;
      flex-wrap: wrap;
    }

    .download-controls input {
      width: 100px;
      padding: 12px;
      border: 2px solid #e2e8f0;
      border-radius: 8px;
      font-size: 16px;
      text-align: center;
    }

    .download-controls button {
      padding: 12px 30px;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn-download {
      background: #2563eb;
      color: white;
    }

    .btn-download:hover {
      background: #1e4fbd;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(37,99,235,0.3);
    }

    .btn-cancel {
      background: #f1f5f9;
      color: #475569;
    }

    .btn-cancel:hover {
      background: #e2e8f0;
    }

    #labelCanvas {
      display: none;
    }

    @media (max-width: 768px) {
      .label-preview {
        width: 100%;
      }

      .download-controls {
        flex-direction: column;
        padding: 15px;
      }

      .download-controls button {
        width: 100%;
        justify-content: center;
      }
    }
  </style>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
</head>
<body>
  <h1>📦 Product Label Preview</h1>

  <div class="preview-container">
    <div id="labelPreview" class="label-preview">
      <div class="product-code" id="productCodeDisplay"></div>
      <div class="qr-section">
        <div class="qr-image">
          <img id="qrImg" src="" alt="QR Code">
        </div>
      </div>
      <div class="price">₹ <span id="sellingPriceValue"></span></div>
    </div>
    <p style="color: #666; margin-top: 10px;">Preview of your label</p>
  </div>

  <div class="download-controls">
    <div style="display: flex; align-items: center; gap: 10px;">
      <label for="copyCount" style="font-weight: bold;">Number of copies:</label>
      <input type="number" id="copyCount" min="1" max="50" value="1">
    </div>
    <button class="btn-download" onclick="downloadAsImage()">
      ⬇️ Download as Image
    </button>
    <button class="btn-cancel" onclick="window.close()">
      ✕ Close
    </button>
  </div>

  <canvas id="labelCanvas"></canvas>

  <script>
    const product = <%- JSON.stringify(product) %>;
    const qrCodeUrl = "<%= qrCodeUrl %>";
    const productCode = product.product_code;
    const sellingPrice = product.selling_price;
    document.getElementById('qrImg').src = qrCodeUrl;
    document.getElementById('productCodeDisplay').textContent = productCode;
    document.getElementById('sellingPriceValue').textContent = sellingPrice;

    function createLabelElement() {
      const div = document.createElement('div');
      div.className = 'label-preview';
      div.style.width = '200px';
      div.style.height = '200px';
      div.style.background = 'white';
      div.style.border = '1px solid #bbb';
      div.style.borderRadius = '0';
      div.style.boxShadow = 'none';
      div.style.display = 'flex';
      div.style.flexDirection = 'column';
      div.style.alignItems = 'center';
      div.style.justifyContent = 'center';
      div.style.padding = '0';
      div.style.fontFamily = "'Times New Roman', serif";
      div.style.fontWeight = 'bold';
      div.innerHTML = `
        <div style="font-size: 18px; font-family: 'Times New Roman', serif; font-weight: bold; background: #e0e7ff; padding: 6px 10px; border-radius: 6px; border-left: 3px solid #2563eb; margin-bottom: 8px;">${productCode}</div>
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
          <div style="width: 100px; height: 100px; border: 2px solid #2563eb; border-radius: 8px; background: white; margin-bottom: 6px; display: flex; align-items: center; justify-content: center;">
            <img src="${qrCodeUrl}" style="width: 90px; height: 90px; object-fit: contain;">
          </div>
        </div>
        <div style="font-size: 16px; font-family: 'Times New Roman', serif; font-weight: bold;">₹ ${sellingPrice}</div>
      `;
      return div;
    }

    async function downloadSingleLabel() {
      const labelElement = createLabelElement();
      document.body.appendChild(labelElement);

      try {
        const canvas = await html2canvas(labelElement, {
          scale: 2,
          backgroundColor: 'white',
          allowTaint: false,
          useCORS: true
        });

        const link = document.createElement('a');
        link.download = `label_${productCode}_${Date.now()}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      } catch (error) {
        console.error('Error generating image:', error);
        alert('Failed to generate image. Please try again.');
      } finally {
        document.body.removeChild(labelElement);
      }
    }

    async function downloadMultipleLabels(count) {
      const container = document.createElement('div');
      container.style.display = 'flex';
      container.style.flexDirection = 'column';
      container.style.gap = '20px';
      container.style.background = 'white';
      container.style.padding = '20px';

      for (let i = 0; i < count; i++) {
        container.appendChild(createLabelElement());
      }

      document.body.appendChild(container);

      try {
        const canvas = await html2canvas(container, {
          scale: 2,
          backgroundColor: 'white',
          allowTaint: false,
          useCORS: true
        });

        const link = document.createElement('a');
        link.download = `labels_${count}_copies_${Date.now()}.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      } catch (error) {
        console.error('Error generating image:', error);
        alert('Failed to generate image. Please try again.');
      } finally {
        document.body.removeChild(container);
      }
    }

    function downloadAsImage() {
      const count = parseInt(document.getElementById('copyCount').value) || 1;

      if (count === 1) {
        downloadSingleLabel();
      } else if (count > 1) {
        downloadMultipleLabels(count);
      }
    }

    document.getElementById('copyCount').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        downloadAsImage();
      }
    });
  </script>
</body>
</html>
