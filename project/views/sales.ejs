<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sales History</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
</head>
<body>
  <%- include('partials/navbar', { currentPage: 'sales' }) %>

  <div class="container mt-4">
    <h1 class="dashboard-title"><i class="fa-solid fa-receipt me-2"></i>Sales History</h1>

    <div class="row mb-4">
      <div class="col-md-6 col-lg-5">
        <div class="input-group">
          <input type="text" id="searchInput" class="form-control" placeholder="Search by bill, product code, customer name or phone" value="<%= typeof search !== 'undefined' ? search : '' %>" autocomplete="off">
          <button class="btn btn-primary" id="searchBtn" type="button">
            <i class="fa-solid fa-search"></i> Search
          </button>
          <button class="btn btn-outline-secondary" id="clearSearchBtn" type="button">
            <i class="fa-solid fa-times"></i> Clear
          </button>
        </div>
        <div id="searchStatus" class="text-muted mt-2 small"></div>
      </div>
    </div>

    <% if (sales.length === 0) { %>
      <div class="alert alert-info">No sales found.</div>
    <% } else { %>
      <div class="accordion" id="salesAccordion">
        <% sales.forEach((sale, index) => { %>
          <div class="accordion-item" data-bill-number="<%= sale.bill_number.toLowerCase() %>">
            <h2 class="accordion-header" id="heading<%= sale.id %>">
              <button class="accordion-button <%= index === 0 ? '' : 'collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= sale.id %>" aria-expanded="<%= index === 0 ? 'true' : 'false' %>" aria-controls="collapse<%= sale.id %>">
                <strong>Bill #<%= sale.bill_number %></strong> –
                <%= sale.sale_date ? new Date(sale.sale_date).toLocaleDateString() : new Date(sale.created_at).toLocaleDateString() %>
                | Total: ₹<%= sale.total_amount.toFixed(2) %>
                | Profit: ₹<%= sale.profit.toFixed(2) %>
                | Payment: <%= sale.payment_method || 'Cash' %>
                <% if (sale.customer_name) { %> | Customer: <%= sale.customer_name %><% } %>
                <% if (sale.total_amount < 0) { %> | <span class="text-warning fw-bold">Return Bill</span><% } %>
                <% if (sale.returned == 1 && sale.total_amount >= 0) { %> | <span class="text-danger fw-bold">Returned</span><% } %>
              </button>
            </h2>
            <div id="collapse<%= sale.id %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" aria-labelledby="heading<%= sale.id %>" data-bs-parent="#salesAccordion">
              <div class="accordion-body">
                <table class="table table-sm">
                  <thead>
                    <tr><th>Product</th><th>Size</th><th>Qty</th><th>Unit Price</th><th>Total</th><th>Profit</th></tr>
                  </thead>
                  <tbody>
                    <% sale.items.forEach(item => { %>
                      <tr>
                        <td><%= item.product_name %><br><small class="text-muted"><%= item.product_code %></small></td>
                        <td><%= item.size || '—' %></td>
                        <td><%= item.quantity %></td>
                        <td>₹<%= item.price_at_sale.toFixed(2) %></td>
                        <td>₹<%= (item.price_at_sale * item.quantity).toFixed(2) %></td>
                        <td>₹<%= item.profit_on_item.toFixed(2) %></td>
                      </tr>
                    <% }); %>
                    <% if (sale.discount_amount > 0) { %>
                      <tr class="text-danger">
                        <td colspan="5" class="text-end"><strong>Discount (<%= sale.discount_type === 'percentage' ? sale.discount_value + '%' : '₹' + sale.discount_value %>):</strong></td>
                        <td>-₹<%= sale.discount_amount.toFixed(2) %></td>
                      </tr>
                    <% } %>
                    <tr class="fw-bold">
                      <td colspan="5" class="text-end">Total Profit after Discount:</td>
                      <td>₹<%= sale.profit.toFixed(2) %></td>
                    </tr>
                  </tbody>
                </table>
                <div class="d-flex gap-2">
                  <a href="/bill/<%= sale.id %>" class="btn btn-sm btn-primary" target="_blank">View Full Bill</a>
                  <% if (sale.total_amount >= 0 && sale.returned == 0) { %>
                    <button class="btn btn-sm btn-warning return-sale-btn" data-sale-id="<%= sale.id %>">Return Sale</button>
                  <% } %>
                  <% if (user && user.role === 'admin') { %>
                    <a href="/sale/edit/<%= sale.id %>" class="btn btn-sm btn-info">Edit</a>
                    <button class="btn btn-sm btn-danger delete-sale-btn" data-sale-id="<%= sale.id %>" data-bill-number="<%= sale.bill_number %>">Delete</button>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Return Modal -->
  <div class="modal fade" id="returnModal" tabindex="-1" aria-labelledby="returnModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form id="returnForm" method="POST" action="">
          <div class="modal-header">
            <h5 class="modal-title">Return Sale</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label for="returnDate" class="form-label">Return Date (optional)</label>
              <input type="date" class="form-control" id="returnDate" name="return_date" value="<%= new Date().toISOString().split('T')[0] %>">
              <div class="form-text">Leave blank to use today's date.</div>
            </div>
            <div class="mb-3">
              <label for="returnReason" class="form-label">Reason for Return (optional)</label>
              <textarea class="form-control" id="returnReason" name="return_reason" rows="2" placeholder="e.g., Damaged, Wrong size, Customer changed mind..."></textarea>
            </div>
            <p>Are you sure you want to return this sale? This will restock items and create a return bill.</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-warning">Confirm Return</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form id="deleteForm" method="POST" action="">
          <div class="modal-header">
            <h5 class="modal-title" id="deleteModalLabel">Delete Sale</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>Are you sure you want to delete <strong id="deleteBillNumber"></strong>?</p>
            <p class="text-danger"><i class="fa-solid fa-triangle-exclamation"></i> This action cannot be undone. All stock will be restored.</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger">Delete Permanently</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const searchInput = document.getElementById('searchInput');
    const searchBtn = document.getElementById('searchBtn');
    const clearBtn = document.getElementById('clearSearchBtn');
    const searchStatus = document.getElementById('searchStatus');

    function performSearch() {
      const term = searchInput.value.trim();
      const url = new URL('/sale/sales', window.location.origin);
      if (term) url.searchParams.set('search', term);
      window.location.href = url.toString();
    }

    function clearSearch() {
      searchInput.value = '';
      window.location.href = '/sale/sales';
    }

    searchBtn.addEventListener('click', performSearch);
    clearBtn.addEventListener('click', clearSearch);
    searchInput.addEventListener('keypress', e => { if (e.key === 'Enter') performSearch(); });

    // Return modal
    const returnModal = new bootstrap.Modal(document.getElementById('returnModal'));
    const returnForm = document.getElementById('returnForm');
    document.querySelectorAll('.return-sale-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        returnForm.action = `/sale/return/${btn.dataset.saleId}`;
        returnModal.show();
      });
    });

    // Delete modal
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));
    const deleteForm = document.getElementById('deleteForm');
    const deleteBillNumberSpan = document.getElementById('deleteBillNumber');
    document.querySelectorAll('.delete-sale-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const saleId = btn.dataset.saleId;
        const billNumber = btn.dataset.billNumber;
        deleteForm.action = `/sale/delete/${saleId}`;
        deleteBillNumberSpan.textContent = `Bill #${billNumber}`;
        deleteModal.show();
      });
    });
  </script>
</body>
</html>
