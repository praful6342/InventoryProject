<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= product.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .product-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .btn-secondary {
      background: linear-gradient(90deg, #64748b 0%, #cbd5e1 100%);
      border: none;
      color: #1e293b;
    }
    .btn-warning {
      background: linear-gradient(90deg, #f59e42 0%, #fef08a 100%);
      border: none;
      color: #92400e;
    }
    .btn-outline-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      color: #fff;
      border: none;
    }
    .table th {
      background-color: #e0e7ef;
      color: #334155;
      font-weight: 600;
    }
    .img-fluid {
      border-radius: 8px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .btn-print {
      background: linear-gradient(90deg, #38bdf8 0%, #bae6fd 100%);
      color: #075985;
      border: none;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { currentPage: 'show' }) %>

  <div class="container mt-4">
    <!-- Hidden element to store product ID for real-time updates -->
    <span id="product-data" data-id="<%= product.id %>" style="display:none;"></span>

    <div class="d-flex justify-content-between align-items-center">
      <h1 id="product-name" class="product-title"><i class="fa-solid fa-box"></i> <%= product.name %></h1>
      <div>
        <span id="update-status" class="text-muted me-2"></span>
        <button id="refresh-now" class="btn btn-sm btn-outline-secondary">Refresh Now</button>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6">
        <table class="table">
          <tr><th>Product Code</th><td><%= product.product_code %></td></tr>
          <tr><th>Category</th><td><%= product.category %></td></tr>
          <tr><th>Name</th><td><%= product.name %></td></tr>
          <tr><th>Supplier</th><td><%= product.supplier %></td></tr>
          <tr>
            <th>Sizes & Stock</th>
            <td id="product-stock">
              <% if (product.has_sizes) { %>
                <% if (product.variants && product.variants.length > 0) { %>
                  <% product.variants.forEach(function(v) { %>
                    <span><%= v.size %>: <%= v.stock %></span><br>
                  <% }); %>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              <% } else { %>
                <% if (product.variants && product.variants[0]) { %>
                  <span>Stock: <%= product.variants[0].stock %></span>
                <% } else { %>
                  <span class="text-muted">—</span>
                <% } %>
              <% } %>
            </td>
          </tr>
          <tr><th>Cost Price</th><td id="product-cost">₹<%= product.cost_price %></td></tr>
          <tr><th>Margin (%)</th><td><%= product.margin_percent %></td></tr>
          <tr><th>Margin (₹)</th><td><%= product.margin_rs %></td></tr>
          <tr><th>Selling Price</th><td id="product-selling">₹<%= product.selling_price %></td></tr>
        </table>
        <div class="d-flex gap-2 flex-wrap">
          <a href="/products" class="btn btn-secondary">Back to list</a>
          <a href="/products/label/<%= product.id %>" class="btn btn-print" target="_blank">Print Label</a>
          <% if (user && user.role === 'admin') { %>
            <a href="/products/edit/<%= product.id %>" class="btn btn-warning">Edit Product</a>
            <form method="POST" action="/products/delete/<%= product.id %>" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');">
              <button type="submit" class="btn btn-danger">Delete Product</button>
            </form>
          <% } %>
        </div>
      </div>
      <div class="col-md-6 text-center">
        <h5>QR Code (scannable)</h5>
        <img src="<%= qrCodeUrl %>" alt="QR Code" class="img-fluid" style="max-width: 300px; border: 1px solid #ddd; padding: 10px;">
        <p class="mt-2">Product ID: <%= product.qr_code %></p>
        <a href="<%= qrCodeUrl %>" download="product-<%= product.qr_code %>-qrcode.png" class="btn btn-sm btn-outline-primary mt-2">Download QR</a>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const productData = document.getElementById('product-data');
    const productId = productData ? parseInt(productData.dataset.id) : null;

    async function fetchProductDetails() {
      if (!productId) return;
      try {
        const response = await fetch(`/api/products/${productId}?_=${Date.now()}`);
        if (!response.ok) throw new Error('Failed to fetch');
        const product = await response.json();
        document.getElementById('product-name').innerHTML = `<i class="fa-solid fa-box"></i> ${product.name}`;
        document.getElementById('product-cost').innerHTML = `₹${product.cost_price}`;
        document.getElementById('product-selling').innerHTML = `₹${product.selling_price}`;
        const stockTd = document.getElementById('product-stock');
        if (product.variants && product.variants.length > 0) {
          stockTd.innerHTML = product.variants.map(v => `<span>${v.size}: ${v.stock}</span>`).join('<br>');
        } else {
          stockTd.innerHTML = '<span class="text-muted">—</span>';
        }
        document.getElementById('update-status').innerText = `Last updated: ${new Date().toLocaleTimeString()}`;
      } catch (error) {
        console.error(error);
        document.getElementById('update-status').innerText = 'Update failed';
        showToast('Failed to update product details', 'danger');
      }
    }

    setInterval(fetchProductDetails, 5000);
    document.getElementById('refresh-now').addEventListener('click', fetchProductDetails);
  </script>
</body>
</html>
