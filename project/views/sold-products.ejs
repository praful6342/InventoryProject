<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sold Products</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    .sold-products-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .filter-section {
      background: white;
      padding: 20px;
      border-radius: 16px;
      margin-bottom: 24px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .table-container {
      background: white;
      border-radius: 16px;
      overflow-x: auto;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .loading-spinner {
      display: inline-block;
      width: 1rem;
      height: 1rem;
      border: 0.2em solid currentColor;
      border-right-color: transparent;
      border-radius: 50%;
      animation: spinner-border .75s linear infinite;
    }
    @keyframes spinner-border {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { currentPage: 'soldProducts' }) %>

  <main>
    <div class="container mt-4">
      <h1 class="sold-products-title"><i class="fa-solid fa-list-ul me-2"></i>Sold Products</h1>

      <div class="filter-section">
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <label class="form-label">Date Range</label>
            <div class="d-flex gap-2">
              <input type="date" id="startDate" class="form-control" value="<%= start_date %>">
              <span>to</span>
              <input type="date" id="endDate" class="form-control" value="<%= end_date %>">
            </div>
          </div>
          <div class="col-md-4">
            <label class="form-label">Search</label>
            <input type="text" id="searchInput" class="form-control" placeholder="Product name or Bill number" value="<%= search %>" autocomplete="off">
          </div>
          <div class="col-md-4">
            <button id="applyFilters" class="btn btn-primary w-100">Apply Filters</button>
          </div>
        </div>
      </div>

      <div class="table-container">
        <table class="table table-striped table-hover mb-0">
          <thead>
              <th>Date</th>
              <th>Bill Number</th>
              <th>Product</th>
              <th>Size</th>
              <th>Quantity</th>
              <th>Price (₹)</th>
              <th>Total (₹)</th>
          </thead>
          <tbody id="itemsTableBody">
            <% if (items.length === 0) { %>
              <tr><td colspan="7" class="text-center">No items found.<?php } else { %>
              <% items.forEach(item => { %>
                   <td><%= new Date(item.sale_date).toLocaleDateString() %></td>
                   <td><%= item.bill_number %></td>
                   <td><%= item.product_name %></td>
                   <td><%= item.size || '—' %></td>
                   <td><%= item.quantity %></td>
                   <td>₹<%= item.price_at_sale.toFixed(2) %></td>
                   <td>₹<%= item.total_amount.toFixed(2) %></td>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination controls -->
      <% if (totalPages > 1) { %>
        <nav aria-label="Page navigation" class="mt-4">
          <ul class="pagination justify-content-center">
            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="#" data-page="<%= currentPage - 1 %>">Previous</a>
            </li>
            <% for (let i = 1; i <= totalPages; i++) { %>
              <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                <a class="page-link" href="#" data-page="<%= i %>"><%= i %></a>
              </li>
            <% } %>
            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="#" data-page="<%= currentPage + 1 %>">Next</a>
            </li>
          </ul>
        </nav>
      <% } %>

    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const startDateInput = document.getElementById('startDate');
    const endDateInput = document.getElementById('endDate');
    const searchInput = document.getElementById('searchInput');
    const applyBtn = document.getElementById('applyFilters');
    const tbody = document.getElementById('itemsTableBody');

    function fetchData(page = 1) {
      const params = new URLSearchParams();
      if (startDateInput.value) params.append('start_date', startDateInput.value);
      if (endDateInput.value) params.append('end_date', endDateInput.value);
      if (searchInput.value) params.append('search', searchInput.value);
      params.append('page', page);
      params.append('_t', Date.now()); // cache buster

      applyBtn.disabled = true;
      applyBtn.innerHTML = '<span class="loading-spinner"></span> Loading...';

      fetch(`/sale/sold-products?${params.toString()}`, {
        headers: { 'Accept': 'application/json' }
      })
        .then(res => res.json())
        .then(data => {
          // Update table rows
          tbody.innerHTML = '';
          if (data.items.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center">No items found.</td></tr>';
          } else {
            data.items.forEach(item => {
              const row = document.createElement('tr');
              row.innerHTML = `
                <td>${new Date(item.sale_date).toLocaleDateString()}</td>
                <td>${item.bill_number}</td>
                <td>${item.product_name}</td>
                <td>${item.size || '—'}</td>
                <td>${item.quantity}</td>
                <td>₹${item.price_at_sale.toFixed(2)}</td>
                <td>₹${item.total_amount.toFixed(2)}</td>
              `;
              tbody.appendChild(row);
            });
          }

          // Update pagination
          const paginationContainer = document.querySelector('.pagination');
          if (data.totalPages > 1) {
            let paginationHtml = `
              <li class="page-item ${data.currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" data-page="${data.currentPage - 1}">Previous</a>
              </li>
            `;
            for (let i = 1; i <= data.totalPages; i++) {
              paginationHtml += `
                <li class="page-item ${i === data.currentPage ? 'active' : ''}">
                  <a class="page-link" href="#" data-page="${i}">${i}</a>
                </li>
              `;
            }
            paginationHtml += `
              <li class="page-item ${data.currentPage === data.totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" data-page="${data.currentPage + 1}">Next</a>
              </li>
            `;
            if (paginationContainer) {
              paginationContainer.innerHTML = paginationHtml;
              attachPaginationHandlers();
            } else {
              // create pagination if it didn't exist
              const nav = document.createElement('nav');
              nav.setAttribute('aria-label', 'Page navigation');
              nav.className = 'mt-4';
              nav.innerHTML = `<ul class="pagination justify-content-center">${paginationHtml}</ul>`;
              document.querySelector('.container').appendChild(nav);
              attachPaginationHandlers();
            }
          } else if (paginationContainer) {
            paginationContainer.remove();
          }
        })
        .catch(err => {
          console.error(err);
          showToast('Error loading data', 'danger');
        })
        .finally(() => {
          applyBtn.disabled = false;
          applyBtn.innerHTML = 'Apply Filters';
        });
    }

    function attachPaginationHandlers() {
      document.querySelectorAll('.pagination .page-link').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const page = link.getAttribute('data-page');
          if (page && !link.parentElement.classList.contains('disabled')) {
            fetchData(parseInt(page));
          }
        });
      });
    }

    applyBtn.addEventListener('click', () => fetchData(1));
    // Optional: trigger on Enter in search
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') fetchData(1);
    });

    // Initial load uses page from server (already loaded). If you want to allow AJAX on first load, you could call fetchData(1) but we already have server-rendered data.
    attachPaginationHandlers();
  </script>
</body>
</html>
