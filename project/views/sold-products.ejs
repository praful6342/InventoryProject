<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sold Products</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    .sold-products-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }

    /* Filter section – improved spacing and no z-index conflicts */
    .filter-section {
      background: white;
      padding: 1.5rem;
      border-radius: 20px;
      margin-bottom: 2rem;
      box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    /* Use Bootstrap's grid system with no custom z-index on inputs */
    .filter-section .form-label {
      font-weight: 600;
      margin-bottom: 0.4rem;
    }

    /* Make sure date inputs don't create stacking context issues */
    input[type="date"] {
      position: static;
    }

    /* Ensure seller dropdown appears above everything when open */
    #sellerFilter {
      position: relative;
      z-index: 5;
    }

    /* Responsive adjustments: stack on small screens */
    @media (max-width: 768px) {
      .filter-section .row [class*="col-"] {
        margin-bottom: 1rem;
      }
      .filter-section .row [class*="col-"]:last-child {
        margin-bottom: 0;
      }
      .d-flex.gap-2 {
        flex-wrap: wrap;
      }
      .d-flex.gap-2 input {
        flex: 1;
        min-width: 130px;
      }
    }

    /* Table styling */
    .table-responsive {
      max-height: 70vh;
      overflow-y: auto;
      border-radius: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .table thead th {
      position: sticky;
      top: 0;
      background-color: #e0e7ef;
      z-index: 10;
      white-space: nowrap;
    }
    .discount-text { color: #dc3545; }
    .loading-spinner {
      display: inline-block;
      width: 1rem;
      height: 1rem;
      border: 0.2em solid currentColor;
      border-right-color: transparent;
      border-radius: 50%;
      animation: spinner-border .75s linear infinite;
    }
    @keyframes spinner-border {
      to { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <%- include('partials/navbar', { currentPage: 'soldProducts' }) %>

  <main>
    <div class="container mt-4">
      <h1 class="sold-products-title"><i class="fa-solid fa-list-ul me-2"></i>Sold Products</h1>

      <div class="filter-section">
        <form id="filterForm">
          <div class="row g-3 align-items-end">
            <div class="col-md-4">
              <label class="form-label">Date Range</label>
              <div class="d-flex gap-2">
                <input type="date" id="startDate" class="form-control" value="<%= start_date %>">
                <span class="align-self-center">—</span>
                <input type="date" id="endDate" class="form-control" value="<%= end_date %>">
              </div>
            </div>
            <div class="col-md-3">
              <label for="sellerFilter" class="form-label">Seller</label>
              <select id="sellerFilter" class="form-select">
                <option value="">All Sellers</option>
                <% sellers.forEach(seller => { %>
                  <option value="<%= seller.id %>" <%= seller_id == seller.id ? 'selected' : '' %>><%= seller.username %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-3">
              <label for="searchInput" class="form-label">Search</label>
              <input type="text" id="searchInput" class="form-control" placeholder="Bill no, product code, customer" value="<%= search %>" autocomplete="off">
            </div>
            <div class="col-md-2">
              <button type="button" id="applyFiltersBtn" class="btn btn-primary w-100">Apply</button>
            </div>
          </div>
        </form>
      </div>

      <div id="itemsContainer">
        <% if (items.length === 0) { %>
          <div class="alert alert-info">No sold products found.</div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-striped table-bordered">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Bill No.</th>
                  <th>Product</th>
                  <th>Code</th>
                  <th>Size</th>
                  <th>Qty</th>
                  <th>Unit Price</th>
                  <th>Original Total</th>
                  <th>Discount Alloc.</th>
                  <th>Net Total</th>
                  <th>Seller</th>
                </tr>
              </thead>
              <tbody>
                <% items.forEach(item => { %>
                  <tr>
                    <td><%= item.sale_date %></td>
                    <td><%= item.bill_number %></td>
                    <td><%= item.product_name %></td>
                    <td><%= item.product_code %></td>
                    <td><%= item.size || '—' %></td>
                    <td><%= item.quantity %></td>
                    <td>₹<%= Number(item.price_at_sale).toFixed(2) %></td>
                    <td>₹<%= Number(item.original_total).toFixed(2) %></td>
                    <td class="<%= item.discount_allocated > 0 ? 'discount-text' : '' %>">
                      <%= item.discount_allocated > 0 ? '-₹' + Number(item.discount_allocated).toFixed(2) : '—' %>
                    </td>
                    <td class="fw-bold">₹<%= Number(item.net_total).toFixed(2) %></td>
                    <td><%= item.seller_name || 'Unknown' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <nav aria-label="Page navigation" class="mt-4">
          <ul class="pagination justify-content-center" id="paginationContainer">
            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="#" data-page="<%= currentPage - 1 %>">Previous</a>
            </li>
            <% for (let i = 1; i <= totalPages; i++) { %>
              <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                <a class="page-link" href="#" data-page="<%= i %>"><%= i %></a>
              </li>
            <% } %>
            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="#" data-page="<%= currentPage + 1 %>">Next</a>
            </li>
          </ul>
        </nav>
      <% } %>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    const startDateInput = document.getElementById('startDate');
    const endDateInput = document.getElementById('endDate');
    const sellerFilter = document.getElementById('sellerFilter');
    const searchInput = document.getElementById('searchInput');
    const applyBtn = document.getElementById('applyFiltersBtn');
    const itemsContainer = document.getElementById('itemsContainer');
    const paginationContainer = document.getElementById('paginationContainer');

    function fetchData(page = 1) {
      const params = new URLSearchParams();
      if (startDateInput.value) params.append('start_date', startDateInput.value);
      if (endDateInput.value) params.append('end_date', endDateInput.value);
      if (sellerFilter.value) params.append('seller_id', sellerFilter.value);
      if (searchInput.value) params.append('search', searchInput.value);
      params.append('page', page);
      params.append('_t', Date.now());

      applyBtn.disabled = true;
      applyBtn.innerHTML = '<span class="loading-spinner"></span> Loading...';

      fetch(`/sale/sold-products?${params.toString()}`, { headers: { 'Accept': 'application/json' } })
        .then(res => res.json())
        .then(data => {
          let html = '';
          if (data.items.length === 0) {
            html = '<div class="alert alert-info">No sold products found.</div>';
          } else {
            html = `
              <div class="table-responsive">
                <table class="table table-striped table-bordered">
                  <thead>
                    <tr>
                      <th>Date</th>
                      <th>Bill No.</th>
                      <th>Product</th>
                      <th>Code</th>
                      <th>Size</th>
                      <th>Qty</th>
                      <th>Unit Price</th>
                      <th>Original Total</th>
                      <th>Discount Alloc.</th>
                      <th>Net Total</th>
                      <th>Seller</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${data.items.map(item => `
                      <tr>
                        <td>${item.sale_date}</td>
                        <td>${item.bill_number}</td>
                        <td>${item.product_name}</td>
                        <td>${item.product_code}</td>
                        <td>${item.size || '—'}</td>
                        <td>${item.quantity}</td>
                        <td>₹${Number(item.price_at_sale).toFixed(2)}</td>
                        <td>₹${Number(item.original_total).toFixed(2)}</td>
                        <td class="${item.discount_allocated > 0 ? 'discount-text' : ''}">
                          ${item.discount_allocated > 0 ? '-₹' + Number(item.discount_allocated).toFixed(2) : '—'}
                        </td>
                        <td class="fw-bold">₹${Number(item.net_total).toFixed(2)}</td>
                        <td>${item.seller_name || 'Unknown'}</td>
                      </tr>
                    `).join('')}
                  </tbody>
                </table>
              </div>
            `;
          }
          itemsContainer.innerHTML = html;

          // Update pagination
          if (data.totalPages > 1) {
            let pagHtml = `
              <li class="page-item ${data.currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" data-page="${data.currentPage - 1}">Previous</a>
              </li>`;
            for (let i = 1; i <= data.totalPages; i++) {
              pagHtml += `
                <li class="page-item ${i === data.currentPage ? 'active' : ''}">
                  <a class="page-link" href="#" data-page="${i}">${i}</a>
                </li>`;
            }
            pagHtml += `
              <li class="page-item ${data.currentPage === data.totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" data-page="${data.currentPage + 1}">Next</a>
              </li>`;
            paginationContainer.innerHTML = pagHtml;
            attachPaginationHandlers();
          } else {
            paginationContainer.innerHTML = '';
          }

          // Update seller dropdown if new data includes sellers (optional)
          if (data.sellers) {
            const currentSeller = sellerFilter.value;
            sellerFilter.innerHTML = '<option value="">All Sellers</option>';
            data.sellers.forEach(seller => {
              sellerFilter.innerHTML += `<option value="${seller.id}" ${currentSeller == seller.id ? 'selected' : ''}>${seller.username}</option>`;
            });
          }
        })
        .catch(err => {
          console.error(err);
          showToast('Error loading data', 'danger');
        })
        .finally(() => {
          applyBtn.disabled = false;
          applyBtn.innerHTML = 'Apply Filters';
        });
    }

    function attachPaginationHandlers() {
      document.querySelectorAll('#paginationContainer .page-link').forEach(link => {
        link.addEventListener('click', e => {
          e.preventDefault();
          const page = link.getAttribute('data-page');
          if (page && !link.parentElement.classList.contains('disabled')) {
            fetchData(parseInt(page));
          }
        });
      });
    }

    applyBtn.addEventListener('click', () => fetchData(1));
    searchInput.addEventListener('keypress', e => { if (e.key === 'Enter') fetchData(1); });
    sellerFilter.addEventListener('change', () => fetchData(1));

    attachPaginationHandlers();
  </script>
</body>
</html>
