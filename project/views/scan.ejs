<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .scanner-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .card {
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      transition: box-shadow 0.2s;
    }
    .card:hover {
      box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-success {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      border: none;
      color: #065f46;
    }
    .btn-danger {
      background: linear-gradient(90deg, #ef4444 0%, #fca5a5 100%);
      border: none;
      color: #991b1b;
    }
    .btn-info {
      background: linear-gradient(90deg, #38bdf8 0%, #bae6fd 100%);
      border: none;
      color: #075985;
    }
    .product-detail {
      background-color: #f1f5f9;
      border-radius: 8px;
      padding: 16px;
    }
    .action-buttons .btn {
      margin-right: 8px;
      margin-bottom: 8px;
    }
  </style>
  <!-- Html5Qrcode library -->
  <script src="https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
  <style>
    #qr-reader {
      width: 100%;
      max-width: 500px;
      margin: 0 auto;
      border: 2px solid #ddd;
      border-radius: 8px;
    }
    #result {
      font-size: 1.2rem;
      font-weight: bold;
      color: #0d6efd;
    }
    .scanner-controls {
      margin-top: 15px;
    }
    .product-detail {
      background-color: #f8f9fa;
      padding: 15px;
      border-radius: 8px;
    }
    .action-buttons {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }
  </style>
</head>
<body>
  <div class="container mt-5">
    <h1 class="scanner-title mb-4"><i class="fa-solid fa-qrcode me-2"></i>QR Code Scanner</h1>
    <div class="row">
      <div class="col-md-6">
        <!-- Scanner container -->
        <div id="qr-reader"></div>
        <div id="qr-reader-results" class="mt-3"></div>
        <!-- Scanner control buttons -->
        <div class="scanner-controls d-flex gap-2">
          <button id="stopBtn" class="btn btn-danger">Stop Scanning</button>
          <button id="startBtn" class="btn btn-success" disabled>Start Scanning</button>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Scanned Product</h5>
            <div id="product-info" class="product-detail">
              <p class="text-muted">Scan a QR code to see product details.</p>
            </div>
            <p class="mt-3"><strong>Scanned ID:</strong> <span id="result">—</span></p>
            <div class="d-flex gap-2">
              <button id="clearBtn" class="btn btn-secondary mt-2">Clear</button>
              <button id="refreshBtn" class="btn btn-info mt-2" disabled>Refresh Info</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Check library loaded
      if (typeof Html5Qrcode === 'undefined') {
        document.getElementById('qr-reader-results').innerHTML = 
          '<div class="alert alert-danger">QR scanner library failed to load. Please refresh.</div>';
        return;
      }

      const qrReaderElement = document.getElementById('qr-reader');
      const resultDiv = document.getElementById('result');
      const productInfoDiv = document.getElementById('product-info');
      const resultsDiv = document.getElementById('qr-reader-results');
      const stopBtn = document.getElementById('stopBtn');
      const startBtn = document.getElementById('startBtn');
      const clearBtn = document.getElementById('clearBtn');
      const refreshBtn = document.getElementById('refreshBtn');

      let html5QrCode = new Html5Qrcode(qrReaderElement.id);
      let isScanning = false;
      let lastScannedId = null; // Store the last scanned product ID

      const config = { 
        fps: 10, 
        qrbox: { width: 250, height: 250 } 
      };

      // Function to fetch and display product details
      function fetchProductDetails(productId) {
        if (!productId) return;

        // Use cache-busting query parameter
        fetch(`/api/products/${productId}?_=${Date.now()}`)
          .then(response => {
            if (!response.ok) {
              throw new Error('Product not found');
            }
            return response.json();
          })
          .then(product => {
            productInfoDiv.innerHTML = `
              <p><strong>Name:</strong> ${product.name}</p>
              <p><strong>Selling Price:</strong> ₹${product.selling_price}</p>
              <p><strong>Cost Price:</strong> ₹${product.cost_price}</p>
              <p><strong>Stock:</strong> ${product.stock}</p>
              <div class="action-buttons">
                <button class="btn btn-primary" onclick="window.location.href='/sell?product=${product.id}'">Sell This</button>
                <button class="btn btn-info" onclick="window.location.href='/products/${product.id}'">View Details</button>
              </div>
            `;
            resultsDiv.innerHTML = '<div class="alert alert-success">Product loaded</div>';
            refreshBtn.disabled = false; // Enable refresh button
          })
          .catch(error => {
            console.error(error);
            resultsDiv.innerHTML = '<div class="alert alert-danger">Product not found or error</div>';
            productInfoDiv.innerHTML = '<p class="text-danger">Product not found</p>';
            refreshBtn.disabled = true;
          });
      }

      // Function to start scanning
      function startScanner() {
        html5QrCode.start(
          { facingMode: "environment" },
          config,
          (decodedText, decodedResult) => {
            // Success callback
            resultDiv.innerText = decodedText;
            lastScannedId = decodedText; // Store the scanned ID
            fetchProductDetails(decodedText);
          },
          (errorMessage) => {
            // Ignore scan errors (they're frequent)
          }
        ).then(() => {
          isScanning = true;
          stopBtn.disabled = false;
          startBtn.disabled = true;
          resultsDiv.innerHTML = '<div class="alert alert-info">Scanner running</div>';
        }).catch(err => {
          console.error("Start failed:", err);
          resultsDiv.innerHTML = '<div class="alert alert-danger">Failed to start camera. Check permissions.</div>';
          stopBtn.disabled = true;
          startBtn.disabled = false;
        });
      }

      // Function to stop scanning
      function stopScanner() {
        if (html5QrCode && isScanning) {
          html5QrCode.stop().then(() => {
            isScanning = false;
            stopBtn.disabled = true;
            startBtn.disabled = false;
            resultsDiv.innerHTML = '<div class="alert alert-warning">Scanner stopped</div>';
          }).catch(err => {
            console.error("Stop error:", err);
            resultsDiv.innerHTML = '<div class="alert alert-danger">Error stopping scanner</div>';
          });
        }
      }

      // Initially start scanning
      startScanner();

      // Event listeners
      stopBtn.addEventListener('click', stopScanner);
      
      startBtn.addEventListener('click', function() {
        if (!isScanning) {
          startScanner();
        }
      });

      clearBtn.addEventListener('click', function() {
        resultDiv.innerText = '—';
        productInfoDiv.innerHTML = '<p class="text-muted">Scan a QR code to see product details.</p>';
        resultsDiv.innerHTML = '';
        lastScannedId = null;
        refreshBtn.disabled = true;
      });

      // Refresh button: re-fetch details for the last scanned product
      refreshBtn.addEventListener('click', function() {
        if (lastScannedId) {
          resultsDiv.innerHTML = '<div class="alert alert-info">Refreshing...</div>';
          fetchProductDetails(lastScannedId);
        }
      });
    });
  </script>
</body>
</html>