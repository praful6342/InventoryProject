<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .scanner-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .card {
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      transition: box-shadow 0.2s;
    }
    .card:hover {
      box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-success {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      border: none;
      color: #065f46;
    }
    .btn-danger {
      background: linear-gradient(90deg, #ef4444 0%, #fca5a5 100%);
      border: none;
      color: #991b1b;
    }
    .btn-info {
      background: linear-gradient(90deg, #38bdf8 0%, #bae6fd 100%);
      border: none;
      color: #075985;
    }
    .product-detail {
      background-color: #f1f5f9;
      border-radius: 8px;
      padding: 16px;
    }
    .action-buttons .btn {
      margin-right: 8px;
      margin-bottom: 8px;
    }
  </style>
  <!-- Html5Qrcode library -->
  <script src="https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
  <style>
    #qr-reader {
      width: 100%;
      max-width: 500px;
      margin: 0 auto;
      border: 2px solid #ddd;
      border-radius: 8px;
    }
    #result {
      font-size: 1.2rem;
      font-weight: bold;
      color: #0d6efd;
    }
    .scanner-controls {
      margin-top: 15px;
    }
    .product-detail {
      background-color: #f8f9fa;
      padding: 15px;
      border-radius: 8px;
    }
    .action-buttons {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link disabled" href="#">Reports</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <h1 class="scanner-title mb-4"><i class="fa-solid fa-qrcode me-2"></i>QR Code Scanner</h1>
    <div class="row">
      <div class="col-md-6">
        <!-- Scanner container -->
        <div id="scanner-section">
          <div id="qr-reader"></div>
          <div id="qr-reader-results" class="mt-3"></div>
          <!-- Scanner control buttons -->
          <div class="scanner-controls d-flex gap-2">
            <button id="scanBtn" class="btn btn-primary">Scan</button>
            <button id="stopBtn" class="btn btn-danger">Stop Scanning</button>
            <button id="startBtn" class="btn btn-success">Scan Next</button>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Scanned Product</h5>
                      <div id="product-info" class="product-detail">
            </div>
            <p class="mt-3"><strong>Scanned ID:</strong> <span id="result">—</span></p>
            <div class="d-flex gap-2">
              <button id="clearBtn" class="btn btn-secondary mt-2">Clear</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Check library loaded
      if (typeof Html5Qrcode === 'undefined') {
        document.getElementById('qr-reader-results').innerHTML = 
          '<div class="alert alert-danger">QR scanner library failed to load. Please refresh.</div>';
        return;
      }

      const qrReaderElement = document.getElementById('qr-reader');
      const resultDiv = document.getElementById('result');
      const productInfoDiv = document.getElementById('product-info');
      const resultsDiv = document.getElementById('qr-reader-results');
      const stopBtn = document.getElementById('stopBtn');
      const startBtn = document.getElementById('startBtn');
      const clearBtn = document.getElementById('clearBtn');

      let html5QrCode = new Html5Qrcode(qrReaderElement.id);
      let isScanning = false;
      let lastScannedId = null; // Store the last scanned product ID
      const scannerSection = document.getElementById('scanner-section');
      // Function to fetch and display product details from backend
        function fetchScannedProductAndDisplay() {
          fetch('/scan/scan-product', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ product_code: lastScannedId })
          })
          .then(response => response.json())
          .then(data => {
            if (!data.product) {
              productInfoDiv.innerHTML = '<p class="text-danger">Product not found.</p>';
              return;
            }
            const product = data.product;
            let totalStock = 0;
            let stockBySize = '';
            if (product.variants && product.variants.length > 0) {
              totalStock = product.variants.reduce((sum, v) => sum + (v.stock || 0), 0);
              stockBySize = product.variants.map(v => `${v.size}: ${v.stock}`).join(', ');
            }
            let html = `<div class="mb-2 p-2 border rounded">
              <strong>${product.name}</strong><br>
              <span><b>Code:</b> ${product.product_code}</span><br>
              <span><b>Category:</b> ${product.category || '-'}</span><br>
              <span><b>Selling Price:</b> ₹${product.selling_price}</span><br>
              <span><b>Current Stock:</b> ${totalStock}</span><br>
              <span><b>Stock by Size:</b> ${stockBySize || '-'}</span><br>
              <a href="/products/${product.id}" class="btn btn-sm btn-outline-primary mt-2">View More Details</a>
            </div>`;
            productInfoDiv.innerHTML = html;
            resultsDiv.innerHTML = '<div class="alert alert-success">Product loaded</div>';
            // Hide scanner section after successful scan
            if (scannerSection) {
              scannerSection.style.display = 'none';
            }
          })
          .catch(error => {
            console.error(error);
            resultsDiv.innerHTML = '<div class="alert alert-danger">Error fetching product</div>';
            productInfoDiv.innerHTML = '<p class="text-danger">Error fetching product</p>';
          });
        }
      // Function to start scanning
      // Debounce flag for scan
      let scanLocked = false;

      function startScanner() {
        if (scannerSection) {
          scannerSection.style.display = '';
        }
        html5QrCode.start(
          { facingMode: "environment" },
          config,
          (decodedText, decodedResult) => {
            if (scanLocked) return;
            scanLocked = true;
            // Success callback
            resultDiv.innerText = decodedText;
            lastScannedId = decodedText; // Store the scanned ID
            fetchScannedProductAndDisplay();
            // Stop scanner after one scan
            stopScanner();
          },
          (errorMessage) => {
            // Ignore scan errors (they're frequent)
          }
        ).then(() => {
          isScanning = true;
          stopBtn.disabled = false;
          startBtn.disabled = true;
          resultsDiv.innerHTML = '<div class="alert alert-info">Scanner running</div>';
        }).catch(err => {
          console.error("Start failed:", err);
          let msg = 'Failed to start camera. ';
          if (err && err.name === 'NotAllowedError') {
            msg += 'Camera access was denied. Please allow camera permissions.';
          } else if (err && err.name === 'NotFoundError') {
            msg += 'No camera device found.';
          } else {
            msg += 'Error: ' + (err.message || err);
          }
          resultsDiv.innerHTML = '<div class="alert alert-danger">' + msg + '</div>';
          stopBtn.disabled = true;
          startBtn.disabled = false;
        });
      }

      // Function to stop scanning
      function stopScanner() {
        if (html5QrCode && isScanning) {
          html5QrCode.stop().then(() => {
            isScanning = false;
            stopBtn.disabled = true;
            startBtn.disabled = false;
            resultsDiv.innerHTML = '<div class="alert alert-warning">Scanner stopped</div>';
          }).catch(err => {
            console.error("Stop error:", err);
            resultsDiv.innerHTML = '<div class="alert alert-danger">Error stopping scanner</div>';
          });
        }
      }

      // Event listeners
      document.getElementById('scanBtn').addEventListener('click', function() {
        scanLocked = false;
        // Clear previous errors
        resultsDiv.innerHTML = '';
        // Check if camera permissions are available
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
          resultsDiv.innerHTML = '<div class="alert alert-danger">Camera API not supported in this browser.</div>';
          return;
        }
        // Try to start the scanner
        try {
          startScanner();
        } catch (err) {
          resultsDiv.innerHTML = '<div class="alert alert-danger">Error starting scanner: ' + err.message + '</div>';
        }
      });

      stopBtn.addEventListener('click', stopScanner);

      startBtn.addEventListener('click', function() {
        scanLocked = false; // Allow next scan
        startScanner();
      });

      clearBtn.addEventListener('click', function() {
        resultDiv.innerText = '—';
        productInfoDiv.innerHTML = '<p class="text-muted">Scan a QR code to see product details.</p>';
        resultsDiv.innerHTML = '';
        lastScannedId = null;
        scanLocked = false; // Unlock scan on clear
        // Show scanner section again
        if (scannerSection) {
          scannerSection.style.display = '';
        }
      });
    });
  </script>
</body>
</html>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</html>