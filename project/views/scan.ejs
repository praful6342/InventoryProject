<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <!-- Html5Qrcode library -->
  <script src="https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
  <style>
    /* Additional styles for cart panel */
    .cart-table {
      background: white;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .cart-table th {
      background-color: #e0e7ef;
      color: #334155;
      font-weight: 600;
    }
    .cart-table td {
      vertical-align: middle;
    }
    .cart-table .quantity-input {
      width: 70px;
      text-align: center;
    }
    .cart-total {
      font-size: 1.2rem;
      font-weight: bold;
      background-color: #f1f5f9;
    }
    .btn-checkout {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      color: #065f46;
      border: none;
      font-weight: 600;
    }
    .cart-header {
      font-weight: 700;
      color: #2563eb;
      margin-bottom: 1rem;
    }
    .remove-item {
      background: none;
      border: none;
      color: #dc3545;
      cursor: pointer;
      font-size: 1.2rem;
    }
    .remove-item:hover {
      color: #b91c1c;
    }
    .quantity-control {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
    }
    .quantity-control button {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      border: 1px solid #dee2e6;
      background: white;
      cursor: pointer;
    }
    .quantity-control button:hover {
      background: #e9ecef;
    }
    .quantity-control input {
      width: 50px;
      text-align: center;
      border: 1px solid #dee2e6;
      border-radius: 4px;
      padding: 0.2rem;
    }
    .empty-cart-message {
      text-align: center;
      color: #6c757d;
      padding: 2rem;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { currentPage: 'scan' }) %>

  <!-- Hidden input to pass the user's role to JavaScript -->
  <input type="hidden" id="user-role" value="<%= user ? user.role : '' %>">

  <div class="container mt-4">
    <div class="row">
      <!-- Left Column: Scanner and Manual Entry -->
      <div class="col-lg-7 mb-4">
        <h3 class="cart-header mb-3"><i class="fa-solid fa-qrcode me-2"></i>Scan or Enter Product</h3>

        <!-- Manual Entry Section with Autocomplete -->
        <div class="card mb-4">
          <div class="card-body">
            <h5 class="card-title"><i class="fa-solid fa-keyboard me-2"></i>Manual Product Entry</h5>
            <div class="row g-2">
              <div class="col-md-8">
                <input type="text" class="form-control form-control-lg" id="manualProductCode" placeholder="Enter product code (e.g., pid:123 or product code)" list="product-codes" autocomplete="off">
                <datalist id="product-codes"></datalist>
              </div>
              <div class="col-md-4">
                <button class="btn btn-primary btn-lg w-100" id="findProductBtn">Find Product</button>
              </div>
            </div>
            <div id="manualError" class="text-danger mt-2" style="display: none;"></div>
          </div>
        </div>

        <!-- Scanner container -->
        <div id="scanner-section">
          <div id="qr-reader"></div>
          <div id="qr-reader-results" class="mt-3"></div>
          <!-- Scanner control buttons -->
          <div class="scanner-controls d-flex gap-2">
            <button id="scanBtn" class="btn btn-primary">Scan</button>
            <button id="stopBtn" class="btn btn-danger">Stop Scanning</button>
            <button id="startBtn" class="btn btn-success">Scan Next</button>
          </div>
        </div>

        <!-- Scanned product details -->
        <div class="card mt-4">
          <div class="card-body">
            <h5 class="card-title">Scanned Product</h5>
            <div id="product-info" class="product-detail"></div>
            <p class="mt-3"><strong>Scanned ID:</strong> <span id="result">—</span></p>
            <div class="d-flex gap-2">
              <button id="clearBtn" class="btn btn-secondary mt-2">Clear</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Cart Panel -->
      <div class="col-lg-5">
        <div class="card shadow-sm">
          <div class="card-body">
            <h4 class="cart-header"><i class="fa-solid fa-cart-shopping me-2"></i>Your Cart</h4>

            <% if (!cart || cart.length === 0) { %>
              <div class="empty-cart-message">
                <i class="fa-solid fa-cart-shopping fa-3x text-muted mb-3"></i>
                <p>Your cart is empty. Scan or enter a product to add items.</p>
              </div>
            <% } else { %>
              <div class="table-responsive">
                <table class="table cart-table table-sm align-middle">
                  <thead>
                    <tr>
                      <th>Item</th>
                      <th>Size</th>
                      <th>Qty</th>
                      <th>Price</th>
                      <th>Total</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody id="cart-items">
                    <% let grandTotal = 0; %>
                    <% cart.forEach(item => { %>
                      <% const itemTotal = item.selling_price * item.quantity; %>
                      <% grandTotal += itemTotal; %>
                      <tr data-product-id="<%= item.productId %>" data-size="<%= item.size %>">
                        <td><%= item.name %></td>
                        <td><%= item.size === 'ONESIZE' ? '—' : item.size %></td>
                        <td>
                          <div class="quantity-control">
                            <button class="qty-decr">-</button>
                            <input type="text" class="qty-input" value="<%= item.quantity %>" data-original="<%= item.quantity %>">
                            <button class="qty-incr">+</button>
                          </div>
                        </td>
                        <td>₹<%= item.selling_price.toFixed(2) %></td>
                        <td class="item-total">₹<%= itemTotal.toFixed(2) %></td>
                        <td><button class="remove-item btn btn-link text-danger p-0"><i class="fa-solid fa-trash"></i></button></td>
                      </tr>
                    <% }); %>
                  </tbody>
                  <tfoot>
                    <tr class="cart-total">
                      <td colspan="4" class="text-end fw-bold">Grand Total:</td>
                      <td colspan="2" class="fw-bold text-success" id="grand-total">₹<%= grandTotal.toFixed(2) %></td>
                    </tr>
                  </tfoot>
                </table>
              </div>

              <div class="d-grid gap-2 mt-3">
                <a href="/sale/checkout" class="btn btn-checkout btn-lg">
                  <i class="fa-solid fa-credit-card me-2"></i>Proceed to Checkout
                </a>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Read the user's role from the hidden input
      const userRole = document.getElementById('user-role')?.value || '';

      // ========== POPULATE PRODUCT CODES DATALIST ==========
      fetch('/api/product-codes')
        .then(res => res.json())
        .then(codes => {
          const datalist = document.getElementById('product-codes');
          datalist.innerHTML = codes.map(code => `<option value="${code}">`).join('');
        })
        .catch(err => console.error('Failed to load product codes', err));

      if (typeof Html5Qrcode === 'undefined') {
        document.getElementById('qr-reader-results').innerHTML =
          '<div class="alert alert-danger">QR scanner library failed to load. Please refresh.</div>';
        return;
      }

      const qrReaderElement = document.getElementById('qr-reader');
      const resultDiv = document.getElementById('result');
      const productInfoDiv = document.getElementById('product-info');
      const resultsDiv = document.getElementById('qr-reader-results');
      const stopBtn = document.getElementById('stopBtn');
      const startBtn = document.getElementById('startBtn');
      const clearBtn = document.getElementById('clearBtn');

      let html5QrCode = new Html5Qrcode(qrReaderElement.id);

      const config = {
        fps: 10,
        qrbox: { width: 250, height: 250 }
      };

      let isScanning = false;
      let lastScannedId = null;
      const scannerSection = document.getElementById('scanner-section');
      let scanLocked = false;

      function startScanner() {
        if (scannerSection) {
          scannerSection.style.display = '';
        }
        html5QrCode.start(
          { facingMode: "environment" },
          config,
          (decodedText) => {
            if (scanLocked) return;
            scanLocked = true;
            resultDiv.innerText = decodedText;
            lastScannedId = decodedText;
            fetchScannedProductAndDisplay();
            stopScanner();
          },
          (errorMessage) => {}
        ).then(() => {
          isScanning = true;
          stopBtn.disabled = false;
          startBtn.disabled = true;
          resultsDiv.innerHTML = '<div class="alert alert-info">Scanner running</div>';
        }).catch(err => {
          console.error("Start failed:", err);
          let msg = 'Failed to start camera. ';
          if (err && err.name === 'NotAllowedError') {
            msg += 'Camera access was denied. Please allow camera permissions.';
          } else if (err && err.name === 'NotFoundError') {
            msg += 'No camera device found.';
          } else {
            msg += 'Error: ' + (err.message || err);
          }
          resultsDiv.innerHTML = '<div class="alert alert-danger">' + msg + '</div>';
          stopBtn.disabled = true;
          startBtn.disabled = false;
        });
      }

      function stopScanner() {
        if (html5QrCode && isScanning) {
          html5QrCode.stop().then(() => {
            isScanning = false;
            stopBtn.disabled = true;
            startBtn.disabled = false;
            resultsDiv.innerHTML = '<div class="alert alert-warning">Scanner stopped</div>';
          }).catch(err => {
            console.error("Stop error:", err);
            resultsDiv.innerHTML = '<div class="alert alert-danger">Error stopping scanner</div>';
          });
        }
      }

      // Function to display product info (reused by scanner and manual lookup)
      function displayProductInfo(product) {
        let html = `<div class="mb-2 p-2 border rounded">
          <strong>${product.name}</strong><br>
          <span><b>Code:</b> ${product.product_code}</span><br>
          <span><b>Category:</b> ${product.category || '-'}</span><br>
          <span><b>Selling Price:</b> ₹${product.selling_price}</span><br>
          <hr>`;

        if (product.has_sizes) {
          let sizeOptions = '';
          if (product.variants && product.variants.length > 0) {
            product.variants.forEach(v => {
              if (v.stock > 0) {
                sizeOptions += `<option value="${v.size}" data-stock="${v.stock}">${v.size} (Stock: ${v.stock})</option>`;
              }
            });
          }
          if (sizeOptions === '') {
            sizeOptions = '<option value="" disabled>No sizes in stock</option>';
          }
          html += `<div class="row g-2">
            <div class="col-md-5">
              <select id="size-select" class="form-select form-select-sm">
                <option value="">Select Size</option>
                ${sizeOptions}
              </select>
            </div>
            <div class="col-md-4">
              <input type="number" id="cart-quantity" class="form-control form-control-sm" value="1" min="1">
            </div>
            <div class="col-md-3">
              <button class="btn btn-success btn-sm w-100" id="add-to-cart">Add to Cart</button>
            </div>
          </div>`;
        } else {
          const stock = product.variants && product.variants[0] ? product.variants[0].stock : 0;
          html += `<div class="row g-2">
            <div class="col-md-8">
              <input type="number" id="cart-quantity" class="form-control form-control-sm" value="1" min="1" max="${stock}">
              <small>Available stock: ${stock}</small>
            </div>
            <div class="col-md-4">
              <button class="btn btn-success btn-sm w-100" id="add-to-cart">Add to Cart</button>
            </div>
          </div>`;
        }

        html += `<hr>
          <div class="d-flex gap-2 mt-2">
            <a href="/products/${product.id}" class="btn btn-sm btn-outline-primary">View Details</a>`;

        // Only admins see Edit and Delete buttons
        if (userRole === 'admin') {
          html += `
            <a href="/products/edit/${product.id}" class="btn btn-sm btn-warning">Edit</a>
            <button class="btn btn-sm btn-danger delete-scanned-product">Delete</button>`;
        }

        html += `
          </div>
        </div>`;
        productInfoDiv.innerHTML = html;

        // Attach add-to-cart handler
        document.getElementById('add-to-cart').addEventListener('click', function() {
          let size = 'ONESIZE';
          let maxStock = 0;
          if (product.has_sizes) {
            const sizeSelect = document.getElementById('size-select');
            size = sizeSelect.value;
            if (!size) {
              showToast('Please select a size', 'warning');
              return;
            }
            maxStock = parseInt(sizeSelect.options[sizeSelect.selectedIndex].dataset.stock);
          } else {
            maxStock = product.variants[0].stock;
          }
          const quantity = parseInt(document.getElementById('cart-quantity').value);
          if (quantity < 1 || quantity > maxStock) {
            showToast(`Quantity must be between 1 and ${maxStock}`, 'warning');
            return;
          }
          setLoading(this, true);
          fetch('/sale/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ productId: product.id, size: size, quantity: quantity })
          })
          .then(res => res.json())
          .then(data => {
            if (data.error) {
              showToast(data.error, 'danger');
            } else {
              showToast('Added to cart!', 'success');
              // Reload page to refresh cart panel
              location.reload();
            }
          })
          .catch(err => {
            console.error(err);
            showToast('Network error', 'danger');
          })
          .finally(() => setLoading(this, false));
        });

        // Attach delete handler (only if button exists, i.e., for admins)
        const deleteBtn = document.querySelector('.delete-scanned-product');
        if (deleteBtn) {
          deleteBtn.addEventListener('click', function() {
            if (confirm('Are you sure you want to delete this product? This action cannot be undone.')) {
              setLoading(this, true);
              fetch(`/products/delete/${product.id}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
              })
              .then(response => {
                if (response.ok) {
                  showToast('Product deleted successfully', 'success');
                  resultDiv.innerText = '—';
                  productInfoDiv.innerHTML = '<p class="text-muted">Scan or enter a product code to see details.</p>';
                  lastScannedId = null;
                  scanLocked = false;
                  if (scannerSection) scannerSection.style.display = '';
                  startScanner();
                } else {
                  showToast('Error deleting product', 'danger');
                }
              })
              .catch(err => {
                console.error(err);
                showToast('Network error', 'danger');
              })
              .finally(() => setLoading(this, false));
            }
          });
        }

        resultsDiv.innerHTML = '<div class="alert alert-success">Product loaded</div>';
        if (scannerSection) scannerSection.style.display = 'none';
      }

      function fetchScannedProductAndDisplay() {
        fetch('/scan/scan-product', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product_code: lastScannedId })
        })
        .then(response => response.json())
        .then(data => {
          if (!data.product) {
            productInfoDiv.innerHTML = '<p class="text-danger">Product not found.</p>';
            return;
          }
          displayProductInfo(data.product);
        })
        .catch(error => {
          console.error(error);
          resultsDiv.innerHTML = '<div class="alert alert-danger">Error fetching product</div>';
          productInfoDiv.innerHTML = '<p class="text-danger">Error fetching product</p>';
        });
      }

      // Manual product lookup
      document.getElementById('findProductBtn').addEventListener('click', function() {
        const code = document.getElementById('manualProductCode').value.trim();
        if (!code) {
          showToast('Please enter a product code', 'warning');
          return;
        }
        setLoading(this, true);
        document.getElementById('manualError').style.display = 'none';

        fetch('/scan/scan-product', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ product_code: code })
        })
        .then(response => response.json())
        .then(data => {
          if (data.error) {
            document.getElementById('manualError').textContent = data.error;
            document.getElementById('manualError').style.display = 'block';
            showToast(data.error, 'danger');
          } else {
            resultDiv.innerText = code;
            lastScannedId = code;
            displayProductInfo(data.product);
            document.getElementById('manualProductCode').value = '';
          }
        })
        .catch(err => {
          console.error(err);
          showToast('Network error', 'danger');
        })
        .finally(() => setLoading(this, false));
      });

      document.getElementById('scanBtn').addEventListener('click', function() {
        scanLocked = false;
        resultsDiv.innerHTML = '';
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
          resultsDiv.innerHTML = '<div class="alert alert-danger">Camera API not supported in this browser.</div>';
          return;
        }
        try {
          startScanner();
        } catch (err) {
          resultsDiv.innerHTML = '<div class="alert alert-danger">Error starting scanner: ' + err.message + '</div>';
        }
      });

      stopBtn.addEventListener('click', stopScanner);

      startBtn.addEventListener('click', function() {
        scanLocked = false;
        startScanner();
      });

      clearBtn.addEventListener('click', function() {
        resultDiv.innerText = '—';
        productInfoDiv.innerHTML = '<p class="text-muted">Scan or enter a product code to see details.</p>';
        resultsDiv.innerHTML = '';
        lastScannedId = null;
        scanLocked = false;
        if (scannerSection) scannerSection.style.display = '';
      });

      setTimeout(() => {
        document.getElementById('scanBtn').click();
      }, 500);

      // ========== CART QUANTITY CONTROLS & REMOVE ==========
      function updateQuantity(productId, size, quantity) {
        fetch('/sale/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, size, quantity })
        })
        .then(res => res.json())
        .then(data => {
          if (data.error) {
            showToast(data.error, 'danger');
          } else {
            updateCartUI(productId, size, quantity);
          }
        })
        .catch(err => {
          console.error(err);
          showToast('Network error', 'danger');
        });
      }

      function updateCartUI(productId, size, newQuantity) {
        const row = document.querySelector(`tr[data-product-id="${productId}"][data-size="${size}"]`);
        if (!row) {
          location.reload();
          return;
        }

        if (newQuantity === 0) {
          row.remove();
          const tbody = document.getElementById('cart-items');
          if (tbody.children.length === 0) {
            const cartCard = document.querySelector('.card-body');
            cartCard.innerHTML = `
              <div class="empty-cart-message">
                <i class="fa-solid fa-cart-shopping fa-3x text-muted mb-3"></i>
                <p>Your cart is empty. Scan or enter a product to add items.</p>
              </div>
            `;
            const checkoutBtn = document.querySelector('.btn-checkout');
            if (checkoutBtn) checkoutBtn.remove();
          }
        } else {
          const qtyInput = row.querySelector('.qty-input');
          qtyInput.value = newQuantity;
          const sellingPrice = parseFloat(row.cells[3].innerText.replace('₹', ''));
          const newItemTotal = sellingPrice * newQuantity;
          const itemTotalCell = row.querySelector('.item-total');
          itemTotalCell.innerText = '₹' + newItemTotal.toFixed(2);
        }

        let grandTotal = 0;
        document.querySelectorAll('#cart-items tr').forEach(row => {
          const totalText = row.querySelector('.item-total').innerText;
          const total = parseFloat(totalText.replace('₹', ''));
          if (!isNaN(total)) grandTotal += total;
        });
        const grandTotalSpan = document.getElementById('grand-total');
        if (grandTotalSpan) grandTotalSpan.innerText = '₹' + grandTotal.toFixed(2);
      }

      const cartItems = document.getElementById('cart-items');
      if (cartItems) {
        cartItems.addEventListener('click', (e) => {
          const btn = e.target.closest('.qty-incr, .qty-decr, .remove-item');
          if (!btn) return;

          const row = btn.closest('tr');
          const productId = parseInt(row.dataset.productId, 10);
          const size = row.dataset.size;

          if (btn.classList.contains('qty-incr')) {
            const input = row.querySelector('.qty-input');
            let newVal = parseInt(input.value) + 1;
            input.value = newVal;
            updateQuantity(productId, size, newVal);
          } else if (btn.classList.contains('qty-decr')) {
            const input = row.querySelector('.qty-input');
            let newVal = parseInt(input.value) - 1;
            if (newVal < 1) newVal = 1;
            input.value = newVal;
            updateQuantity(productId, size, newVal);
          } else if (btn.classList.contains('remove-item')) {
            updateQuantity(productId, size, 0);
          }
        });

        cartItems.addEventListener('change', (e) => {
          const input = e.target.closest('.qty-input');
          if (!input) return;
          const row = input.closest('tr');
          const productId = parseInt(row.dataset.productId, 10);
          const size = row.dataset.size;
          let newVal = parseInt(input.value);
          if (isNaN(newVal) || newVal < 1) newVal = 1;
          input.value = newVal;
          updateQuantity(productId, size, newVal);
        });
      }
    });
  </script>
</body>
</html>
