<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bill #<%= sale.bill_number %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    @media print {
      .no-print { display: none; }
    }
    .bill-container {
      max-width: 800px;
      margin: 0 auto;
      padding: 20px;
      border: 1px solid #ddd;
      border-radius: 8px;
    }
    .bill-header {
      text-align: center;
      margin-bottom: 30px;
    }
    .bill-header h2 {
      margin-bottom: 5px;
    }
    .return-badge {
      color: #dc3545;
      font-weight: bold;
      font-size: 1.2rem;
    }
    .bill-details {
      margin-bottom: 20px;
    }
    .bill-table {
      width: 100%;
      border-collapse: collapse;
    }
    .bill-table th, .bill-table td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: left;
    }
    .bill-table th {
      background-color: #f2f2f2;
    }
    .total-row {
      font-weight: bold;
    }
    .discount-row {
      color: #dc3545;
    }
    .negative-amount {
      color: #dc3545;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { currentPage: 'bill' }) %>

  <div class="container mt-4">
    <div class="bill-container">
      <div class="bill-header">
        <h2>Your Clothing Store</h2>
        <% if (sale.total_amount < 0) { %>
          <p class="return-badge">RETURN BILL</p>
        <% } else { %>
          <p>Invoice</p>
        <% } %>
      </div>

      <div class="bill-details">
        <p><strong>Bill Number:</strong> <%= sale.bill_number %></p>
        <p><strong>Date:</strong>
          <% if (sale.sale_date) { %>
            <%= new Date(sale.sale_date + 'T12:00:00').toLocaleDateString() %>
          <% } else { %>
            <%= new Date(sale.created_at + 'Z').toLocaleString() %>
          <% } %>
        </p>
        <p><strong>Payment Method:</strong> <%= sale.payment_method || 'Cash' %></p>
        <% if (sale.customer_name) { %>
          <p><strong>Customer:</strong> <%= sale.customer_name %></p>
          <% if (sale.customer_phone) { %><p><strong>Phone:</strong> <%= sale.customer_phone %></p><% } %>
          <% if (sale.customer_email) { %><p><strong>Email:</strong> <%= sale.customer_email %></p><% } %>
        <% } else { %>
          <p><strong>Customer:</strong> Walk-in Customer</p>
        <% } %>
      </div>

      <table class="bill-table">
        <thead>
          <tr>
            <th>Item</th>
            <th>Size</th>
            <th>Quantity</th>
            <th>Unit Price (₹)</th>
            <th>Total (₹)</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(item => { %>
          <tr>
            <td><%= item.product_name %></td>
            <td><%= item.size || '—' %></td>
            <td><%= item.quantity %></td>
            <td>₹<%= item.price_at_sale.toFixed(2) %></td>
            <td class="<%= (item.price_at_sale * item.quantity) < 0 ? 'negative-amount' : '' %>">
              ₹<%= (item.price_at_sale * item.quantity).toFixed(2) %>
            </td>
          </tr>
          <% }) %>

          <!-- Discount row (if discount was applied) -->
          <% if (sale.discount_amount && sale.discount_amount > 0) { %>
          <tr class="discount-row">
            <td colspan="4" style="text-align: right;">Discount (<%= sale.discount_type === 'percentage' ? sale.discount_value + '%' : '₹' + sale.discount_value %>):</td>
            <td>-₹<%= sale.discount_amount.toFixed(2) %></td>
          </tr>
          <% } %>

          <tr class="total-row">
            <td colspan="4" style="text-align: right;">Total Amount:</td>
            <td class="<%= sale.total_amount < 0 ? 'negative-amount' : '' %>">
              ₹<%= sale.total_amount.toFixed(2) %>
            </td>
          </tr>
        </tbody>
      </table>

      <p class="mt-3"><strong>Thank you for your purchase!</strong></p>

      <div class="no-print mt-4">
        <button class="btn btn-primary" onclick="window.print()">Print Bill</button>
        <a href="/" class="btn btn-secondary">Back to Home</a>
        <a href="/scan" class="btn btn-success">New Scan</a>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
