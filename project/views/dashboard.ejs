<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="/js/app.js" defer></script>
  <style>
    .filter-buttons .btn {
      margin-right: 8px;
      margin-bottom: 8px;
    }
    .filter-buttons .btn.active {
      background-color: #2563eb;
      color: white;
      border-color: #2563eb;
    }
    .custom-range, .month-year-picker {
      display: inline-flex;
      gap: 8px;
      align-items: center;
      margin-right: 16px;
    }
    .loading-spinner {
      display: inline-block;
      width: 1rem;
      height: 1rem;
      border: 0.2em solid currentColor;
      border-right-color: transparent;
      border-radius: 50%;
      animation: spinner-border .75s linear infinite;
    }
    @keyframes spinner-border {
      to { transform: rotate(360deg); }
    }
    .payment-method-card {
      background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
      border-left: 4px solid #2563eb;
      transition: transform 0.2s;
    }
    .payment-method-card:hover {
      transform: translateY(-2px);
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { currentPage: 'dashboard' }) %>

  <main class="container">
    <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
      <h1 class="dashboard-title mb-0">Dashboard</h1>
      <div class="filter-buttons mt-2 mt-md-0">
        <button class="btn btn-outline-primary btn-sm" data-range="today">Today</button>
        <button class="btn btn-outline-primary btn-sm" data-range="week">This Week</button>
        <button class="btn btn-outline-primary btn-sm" data-range="month">This Month</button>
        <button class="btn btn-outline-primary btn-sm" data-range="all">All Time</button>
      </div>
    </div>

    <!-- Additional filters row -->
    <div class="row mb-4">
      <div class="col-md-6 mb-2">
        <div class="custom-range d-flex flex-wrap align-items-center gap-2">
          <label class="fw-bold">Custom Date Range:</label>
          <input type="date" id="startDate" class="form-control form-control-sm w-auto" value="<%= start_date %>">
          <span>to</span>
          <input type="date" id="endDate" class="form-control form-control-sm w-auto" value="<%= end_date %>">
          <button id="applyRangeBtn" class="btn btn-sm btn-success">Apply</button>
        </div>
      </div>
      <div class="col-md-6 mb-2">
        <div class="month-year-picker d-flex flex-wrap align-items-center gap-2">
          <label class="fw-bold">Select Month/Year:</label>
          <input type="month" id="monthYear" class="form-control form-control-sm w-auto" value="<%= month_year %>">
          <button id="applyMonthBtn" class="btn btn-sm btn-info">Show Month</button>
        </div>
      </div>
    </div>

    <!-- First row: quantities, profit, total sales -->
    <div class="row" id="sales-metrics">
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Quantities Sold</h5>
            <p class="display-5" id="qtySold"><%= qtySold %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Profit</h5>
            <p class="display-5 text-success" id="profit">₹<%= profit %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Sales</h5>
            <p class="display-5 text-primary" id="totalSales">₹<%= totalSales %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- New row: Payment Method Breakdown -->
    <div class="row mb-4" id="payment-breakdown-row">
      <div class="col-12">
        <div class="card">
          <div class="card-header bg-white">
            <h5 class="mb-0"><i class="fa-solid fa-credit-card me-2"></i>Sales by Payment Method</h5>
          </div>
          <div class="card-body">
            <div class="row" id="payment-breakdown-container">
              <% if (paymentBreakdown && paymentBreakdown.length > 0) { %>
                <% paymentBreakdown.forEach(method => { %>
                  <div class="col-md-3 col-sm-6 mb-3">
                    <div class="card payment-method-card h-100">
                      <div class="card-body">
                        <h6 class="card-subtitle mb-2 text-muted">
                          <% if (method.payment_method === 'Cash') { %>
                            <i class="fa-solid fa-money-bill-wave me-1"></i>
                          <% } else if (method.payment_method === 'UPI') { %>
                            <i class="fa-solid fa-mobile-alt me-1"></i>
                          <% } else if (method.payment_method === 'Card') { %>
                            <i class="fa-regular fa-credit-card me-1"></i>
                          <% } else { %>
                            <i class="fa-solid fa-receipt me-1"></i>
                          <% } %>
                          <%= method.payment_method || 'Other' %>
                        </h6>
                        <p class="card-text display-6 fw-bold text-primary">₹<%= method.total.toFixed(2) %></p>
                      </div>
                    </div>
                  </div>
                <% }); %>
              <% } else { %>
                <div class="col-12 text-center text-muted py-4">
                  <i class="fa-solid fa-chart-simple fa-2x mb-2"></i>
                  <p>No sales data for this period.</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Second row: stock and inventory values (global, not affected by date) -->
    <div class="row">
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Current Stock (units)</h5>
            <p class="display-5 text-primary"><%= stock %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Inventory Value (Cost)</h5>
            <p class="display-6 text-warning">₹<%= totalCost %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Inventory Value (Selling)</h5>
            <p class="display-6 text-info">₹<%= totalSelling %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Chart row -->
    <div class="row mt-4">
      <div class="col-md-12">
        <div class="card p-3">
          <h4 class="mb-3">Daily Sales Trend</h4>
          <canvas id="salesChart" style="max-height: 400px;"></canvas>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    let chart;

    // Helper to build URL with query parameters
    function buildUrl(params) {
      const url = new URL('/dashboard', window.location.origin);
      Object.keys(params).forEach(key => {
        if (params[key] && params[key] !== '') {
          url.searchParams.append(key, params[key]);
        }
      });
      return url.toString();
    }

    // Update dashboard numbers, chart, and payment breakdown
    async function updateDashboard(url) {
      try {
        const response = await fetch(url, {
          headers: { 'Accept': 'application/json' }
        });
        if (!response.ok) throw new Error('Network response was not ok');
        const data = await response.json();

        // Update metric cards
        document.getElementById('qtySold').innerText = data.qtySold;
        document.getElementById('profit').innerHTML = `₹${data.profit}`;
        document.getElementById('totalSales').innerHTML = `₹${data.totalSales}`;

        // Update payment breakdown
        const paymentContainer = document.getElementById('payment-breakdown-container');
        if (data.paymentBreakdown && data.paymentBreakdown.length > 0) {
          let paymentHtml = '';
          data.paymentBreakdown.forEach(method => {
            let icon = '';
            if (method.payment_method === 'Cash') {
              icon = '<i class="fa-solid fa-money-bill-wave me-1"></i>';
            } else if (method.payment_method === 'UPI') {
              icon = '<i class="fa-solid fa-mobile-alt me-1"></i>';
            } else if (method.payment_method === 'Card') {
              icon = '<i class="fa-regular fa-credit-card me-1"></i>';
            } else {
              icon = '<i class="fa-solid fa-receipt me-1"></i>';
            }
            paymentHtml += `
              <div class="col-md-3 col-sm-6 mb-3">
                <div class="card payment-method-card h-100">
                  <div class="card-body">
                    <h6 class="card-subtitle mb-2 text-muted">
                      ${icon} ${method.payment_method || 'Other'}
                    </h6>
                    <p class="card-text display-6 fw-bold text-primary">₹${method.total.toFixed(2)}</p>
                  </div>
                </div>
              </div>
            `;
          });
          paymentContainer.innerHTML = paymentHtml;
        } else {
          paymentContainer.innerHTML = `
            <div class="col-12 text-center text-muted py-4">
              <i class="fa-solid fa-chart-simple fa-2x mb-2"></i>
              <p>No sales data for this period.</p>
            </div>
          `;
        }

        // Update chart
        if (chart) {
          chart.data.labels = data.chartLabels;
          chart.data.datasets[0].data = data.chartValues;
          chart.update();
        } else {
          // Initialize chart if not yet created
          const ctx = document.getElementById('salesChart').getContext('2d');
          chart = new Chart(ctx, {
            type: 'bar',
            data: {
              labels: data.chartLabels,
              datasets: [{
                label: 'Sales (₹)',
                data: data.chartValues,
                backgroundColor: 'rgba(37, 99, 235, 0.5)',
                borderColor: '#2563eb',
                borderWidth: 1
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: true,
              scales: {
                y: {
                  beginAtZero: true,
                  title: { display: true, text: 'Amount (₹)' }
                },
                x: {
                  title: { display: true, text: 'Date' }
                }
              }
            }
          });
        }
      } catch (error) {
        console.error('Error fetching dashboard data:', error);
        showToast('Failed to load data. Please try again.', 'danger');
      }
    }

    // Handle preset range buttons
    document.querySelectorAll('.filter-buttons .btn').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        const range = this.dataset.range;
        // Clear custom inputs
        document.getElementById('startDate').value = '';
        document.getElementById('endDate').value = '';
        document.getElementById('monthYear').value = '';
        // Update active state
        document.querySelectorAll('.filter-buttons .btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        // Fetch data
        updateDashboard(buildUrl({ range }));
      });
    });

    // Handle custom date range
    document.getElementById('applyRangeBtn').addEventListener('click', () => {
      const start = document.getElementById('startDate').value;
      const end = document.getElementById('endDate').value;
      if (!start || !end) {
        showToast('Please select both start and end dates.', 'warning');
        return;
      }
      if (new Date(start) > new Date(end)) {
        showToast('Start date cannot be after end date.', 'warning');
        return;
      }
      document.querySelectorAll('.filter-buttons .btn').forEach(b => b.classList.remove('active'));
      document.getElementById('monthYear').value = '';
      updateDashboard(buildUrl({ start_date: start, end_date: end }));
    });

    // Handle month/year selection
    document.getElementById('applyMonthBtn').addEventListener('click', () => {
      const monthYear = document.getElementById('monthYear').value;
      if (!monthYear) {
        showToast('Please select a month and year.', 'warning');
        return;
      }
      document.getElementById('startDate').value = '';
      document.getElementById('endDate').value = '';
      document.querySelectorAll('.filter-buttons .btn').forEach(b => b.classList.remove('active'));
      updateDashboard(buildUrl({ month_year: monthYear }));
    });

    // Set initial active button if a preset range is currently applied
    const currentRange = '<%= range %>';
    if (currentRange && ['today','week','month','all'].includes(currentRange)) {
      const activeBtn = document.querySelector(`.filter-buttons .btn[data-range="${currentRange}"]`);
      if (activeBtn) activeBtn.classList.add('active');
    }

    // Initial load: create chart with server‑provided data
    document.addEventListener('DOMContentLoaded', () => {
      const initialLabels = <%- JSON.stringify(chartLabels) %>;
      const initialValues = <%- JSON.stringify(chartValues) %>;
      const ctx = document.getElementById('salesChart').getContext('2d');
      chart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: initialLabels,
          datasets: [{
            label: 'Sales (₹)',
            data: initialValues,
            backgroundColor: 'rgba(37, 99, 235, 0.5)',
            borderColor: '#2563eb',
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          scales: {
            y: {
              beginAtZero: true,
              title: { display: true, text: 'Amount (₹)' }
            },
            x: {
              title: { display: true, text: 'Date' }
            }
          }
        }
      });
    });
  </script>
</body>
</html>
