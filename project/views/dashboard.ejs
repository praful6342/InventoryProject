<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="/js/app.js" defer></script>
</head>
<body>
  <!-- Navigation Bar (replace with partial if you have created one) -->
  <nav class="navbar navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">Sales & Inventory App</a>
      <ul class="navbar-nav d-flex flex-row flex-wrap w-100 justify-content-end">
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link active" href="/dashboard">Dashboard</a></li>
          <li class="nav-item"><a class="nav-link" href="/sale/cart">Cart</a></li>
          <li class="nav-item"><a class="nav-link" href="/sale/sales">Sales</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container">
    <h1 class="dashboard-title mb-4">Today's Dashboard</h1>

    <!-- First row: quantities, profit, total sales -->
    <div class="row">
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Quantities Sold Today</h5>
            <p class="display-5"><%= qtySold %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Today's Profit</h5>
            <p class="display-5 text-success">₹<%= profit %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Sales Today</h5>
            <p class="display-5 text-primary">₹<%= totalSales %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Second row: stock and inventory values -->
    <div class="row">
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Current Stock (units)</h5>
            <p class="display-5 text-primary"><%= stock %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Inventory Value (Cost)</h5>
            <p class="display-6 text-warning">₹<%= totalCost %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-4">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Inventory Value (Selling)</h5>
            <p class="display-6 text-info">₹<%= totalSelling %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Chart row (placeholder data – replace with real API call later) -->
    <div class="row mt-4">
      <div class="col-md-12">
        <div class="card p-3">
          <h4 class="mb-3">Sales Trend (Last 7 Days)</h4>
          <canvas id="salesChart" style="max-height: 400px;"></canvas>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script>
    // Example data – replace with actual data from backend
    const ctx = document.getElementById('salesChart').getContext('2d');
    new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['Day 1', 'Day 2', 'Day 3', 'Day 4', 'Day 5', 'Day 6', 'Day 7'],
        datasets: [{
          label: 'Sales (₹)',
          data: [1200, 1900, 3000, 5000, 2300, 3400, 4500],
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37,99,235,0.1)',
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false }
        }
      }
    });
  </script>
</body>
</html>
