<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Checkout</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/custom.css">
  <script src="/js/app.js" defer></script>
  <style>
    .checkout-title {
      font-weight: 700;
      color: #2563eb;
      text-align: center;
      margin-bottom: 24px;
    }
    .card {
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .btn-success {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      border: none;
      color: #065f46;
    }
    .payment-row {
      background: #f8fafc;
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 10px;
      border: 1px solid #e2e8f0;
    }
    .remove-payment {
      cursor: pointer;
      color: #dc3545;
    }
    .remove-payment:hover {
      color: #b91c1c;
    }
    .remaining-amount {
      font-size: 1.2rem;
      font-weight: bold;
    }
    .change-display {
      font-size: 1.1rem;
      font-weight: bold;
      color: #059669;
    }
  </style>
</head>
<body>

  <%- include('partials/navbar', { currentPage: 'checkout' }) %>

  <div class="container mt-4">
    <h1 class="checkout-title"><i class="fa-solid fa-credit-card me-2"></i>Checkout</h1>

    <div class="row">
      <div class="col-md-7">
        <div class="card p-4">
          <form action="/sale/checkout" method="POST" id="checkoutForm">
            <!-- Customer Information -->
            <h4 class="mb-3">Customer Information (Optional)</h4>
            <div class="mb-3">
              <label for="customerName" class="form-label">Customer Name</label>
              <input type="text" class="form-control" id="customerName" name="customerName" autocomplete="off">
            </div>
            <div class="mb-3">
              <label for="customerPhone" class="form-label">Phone Number</label>
              <input type="tel" class="form-control" id="customerPhone" name="customerPhone" autocomplete="off">
            </div>
            <div class="mb-3">
              <label for="customerEmail" class="form-label">Email Address</label>
              <input type="email" class="form-control" id="customerEmail" name="customerEmail" autocomplete="off">
            </div>

            <!-- Sale Date (Required) - No default value -->
            <div class="mb-3">
              <label for="saleDate" class="form-label">Sale Date <span class="text-danger">*</span></label>
              <input type="date" class="form-control" id="saleDate" name="sale_date" required>
              <small class="text-muted">Select the date of this sale.</small>
            </div>

            <!-- Discount Section -->
            <div class="card p-4 mt-3">
              <h4 class="mb-3">Apply Discount (Optional)</h4>
              <div class="mb-3">
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="discount_type" id="discount_percent" value="percentage">
                  <label class="form-check-label" for="discount_percent">Percentage (%)</label>
                </div>
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="discount_type" id="discount_fixed" value="fixed">
                  <label class="form-check-label" for="discount_fixed">Fixed Amount (₹)</label>
                </div>
              </div>
              <div class="row">
                <div class="col-md-6">
                  <input type="number" step="0.01" class="form-control" id="discount_value" name="discount_value" min="0" placeholder="Enter value" autocomplete="off">
                </div>
                <div class="col-md-6">
                  <p class="mt-2"><strong>Total after discount: </strong><span id="discounted_total">₹<%= total.toFixed(2) %></span></p>
                </div>
              </div>
            </div>

            <!-- Split Payments Section -->
            <div class="card p-4 mt-3">
              <h4 class="mb-3">Payment Details</h4>
              <div id="payments-container">
                <div class="payment-row" data-index="0">
                  <div class="row g-2 align-items-center">
                    <div class="col-md-5">
                      <label class="form-label">Payment Method</label>
                      <select class="form-select payment-method" name="payments[0][method]" required>
                        <option value="">Select</option>
                        <option value="Cash">Cash</option>
                        <option value="UPI">UPI</option>
                        <option value="Card">Card</option>
                      </select>
                    </div>
                    <div class="col-md-5">
                      <label class="form-label">Amount (₹)</label>
                      <input type="number" step="0.01" class="form-control payment-amount" name="payments[0][amount]" min="0" step="0.01" required>
                    </div>
                    <div class="col-md-2 text-center">
                      <i class="fa-solid fa-trash remove-payment" style="display: none;"></i>
                    </div>
                  </div>
                </div>
              </div>
              <button type="button" class="btn btn-outline-primary mt-2" id="addPaymentBtn">
                <i class="fa-solid fa-plus"></i> Add another payment method
              </button>
              <hr>
              <div class="row mt-2">
                <div class="col-md-6">
                  <strong>Remaining to pay:</strong>
                </div>
                <div class="col-md-6 text-end">
                  <span id="remainingAmount" class="remaining-amount">₹<%= total.toFixed(2) %></span>
                </div>
              </div>
              <div class="row mt-1" id="changeRow" style="display: none;">
                <div class="col-md-6">
                  <strong>Change to return:</strong>
                </div>
                <div class="col-md-6 text-end">
                  <span id="changeAmount" class="change-display">₹0.00</span>
                </div>
              </div>
              <div class="alert alert-warning mt-3" id="warningMsg" style="display: none;"></div>
            </div>

            <button type="submit" class="btn btn-success btn-lg w-100 mt-4" id="submitBtn">Complete Sale</button>
          </form>
        </div>
      </div>

      <div class="col-md-5">
        <div class="card p-4">
          <h4 class="mb-3">Order Summary</h4>
          <ul class="list-group list-group-flush">
            <% cart.forEach(item => { %>
              <% const itemTotal = item.selling_price * item.quantity; %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <%= item.name %> (<%= item.size === 'ONESIZE' ? '—' : item.size %>) x <%= item.quantity %>
                <span class="badge bg-primary rounded-pill">₹<%= itemTotal.toFixed(2) %></span>
              </li>
            <% }); %>
            <li class="list-group-item d-flex justify-content-between align-items-center fw-bold">
              Total
              <span class="badge bg-success rounded-pill fs-6" id="orderTotal">₹<%= total.toFixed(2) %></span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <!-- External split-payment logic (handles discount rounding, payments, etc.) -->
  <script src="/js/checkout-payments.js"></script>
</body>
</html>
