<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clothing Store Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-5">
    <h1 class="mb-4">Clothing Store Management</h1>
    <div class="row">
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Manage Products</h5>
            <p class="card-text">Add, edit, and view products. Generate QR codes.</p>
            <a href="/products" class="btn btn-primary">Go to Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Scan QR Code</h5>
            <p class="card-text">Scan a product QR code to start a sale.</p>
            <a href="/scan" class="btn btn-success">Open Scanner</a>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title">New Sale</h5>
            <p class="card-text">Manually select a product and create a sale.</p>
            <a href="/sell" class="btn btn-warning">Create Sale</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>