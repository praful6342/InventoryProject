<!DOCTYPE html>
<html lang="en">
<head>
  <!-- ... head content same as before ... -->
</head>
<body>
  <!-- Navigation Bar (same) -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <!-- ... -->
  </nav>

  <div class="container mt-4">
    <h1 class="dashboard-title"><i class="fa-solid fa-boxes-stacked me-2"></i>Products Dashboard</h1>

    <!-- NEW: Totals Card -->
    <div class="row mb-4">
      <div class="col-md-6">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Cost Price of All Products</h5>
            <p class="display-6 text-warning" id="totalCostPrice">₹0.00</p>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card text-center">
          <div class="card-body">
            <h5 class="card-title">Total Selling Price of All Products</h5>
            <p class="display-6 text-info" id="totalSellingPrice">₹0.00</p>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
      <!-- ... buttons ... -->
    </div>

    <!-- Add Product Modal (unchanged) -->
    <div class="modal fade" id="addProductModal" ...>...</div>

    <form id="bulk-delete-form" ...>...</form>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // (All existing JavaScript remains, but we add calculation of totals)

    // Modify the fetchProducts function to also update totals
    async function fetchProducts() {
      try {
        const response = await fetch('/api/products?_=' + Date.now());
        if (!response.ok) throw new Error('Failed to fetch');
        const products = await response.json();

        const selectedIds = new Set(getSelectedProductIds());
        const tbody = document.getElementById('products-table-body');

        // Calculate totals
        let totalCost = 0, totalSelling = 0;
        products.forEach(product => {
          const costPrice = parseFloat(product.cost_price) || 0;
          const sellingPrice = parseFloat(product.selling_price) || 0;
          // Sum over all variants (stock)
          if (product.variants && product.variants.length > 0) {
            product.variants.forEach(variant => {
              const stock = parseInt(variant.stock) || 0;
              totalCost += costPrice * stock;
              totalSelling += sellingPrice * stock;
            });
          }
        });

        document.getElementById('totalCostPrice').innerText = `₹${totalCost.toFixed(2)}`;
        document.getElementById('totalSellingPrice').innerText = `₹${totalSelling.toFixed(2)}`;

        // ... rest of existing fetchProducts code (populate table, etc.)
        if (products.length === 0) {
          tbody.innerHTML = '<tr><td colspan="13" class="text-center">No products found.</td></tr>';
        } else {
          tbody.innerHTML = products.map(product => `
            <tr>
              <td><input type="checkbox" class="product-checkbox" name="productIds[]" value="${product.id}" ${selectedIds.has(product.id) ? 'checked' : ''}></td>
              <td>${product.product_code}</td>
              <td>${product.category}</td>
              <td>${product.name}</td>
              <td>${product.supplier}</td>
              <td>
                ${product.variants && product.variants.length > 0
                  ? product.variants.map(v => `${v.size}: ${v.stock}`).join('<br>')
                  : '<span class="text-muted">—</span>'}
              </td>
              <td>₹${product.cost_price}</td>
              <td>${product.margin_percent}%</td>
              <td>${product.margin_rs}</td>
              <td>₹${product.selling_price}</td>
              <td>
                <a href="/products/${product.id}">
                  <img src="/api/qr/${product.qr_code}" alt="QR" style="width: 50px; height: 50px;">
                </a>
              </td>
              <td>
                <a href="/products/${product.id}" class="btn btn-sm btn-info">View</a>
                <a href="/products/edit/${product.id}" class="btn btn-sm btn-warning">Edit</a>
                <form method="POST" action="/products/delete/${product.id}" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this product? This action cannot be undone.');">
                  <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          `).join('');
        }

        updateBulkDeleteBtn();
        updateSelectAllCheckbox();
        document.getElementById('update-status').innerText = `Last updated: ${new Date().toLocaleTimeString()}`;
      } catch (error) {
        console.error(error);
        document.getElementById('products-table-body').innerHTML = '<tr><td colspan="13" class="text-center text-danger">Error loading products</td></tr>';
      }
    }

    // All other functions remain unchanged...
  </script>
</body>
</html>