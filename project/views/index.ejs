<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clothing Store Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #f8fafc 0%, #e0e7ef 100%);
      font-family: 'Segoe UI', 'Roboto', Arial, sans-serif;
    }
    .dashboard-title {
      font-weight: 700;
      color: #2d3748;
      letter-spacing: 1px;
      margin-bottom: 24px;
      text-align: center;
    }
    .card {
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      transition: box-shadow 0.2s;
    }
    .card:hover {
      box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    }
    .card-title {
      font-weight: 600;
      color: #2563eb;
    }
    .btn-primary {
      background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
      border: none;
    }
    .btn-success {
      background: linear-gradient(90deg, #22c55e 0%, #a7f3d0 100%);
      border: none;
      color: #065f46;
    }
    .btn-warning {
      background: linear-gradient(90deg, #f59e42 0%, #fef08a 100%);
      border: none;
      color: #92400e;
    }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold text-primary" href="/">InventoryApp</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/products">Products</a></li>
          <li class="nav-item"><a class="nav-link" href="/scan">Scan</a></li>
          <li class="nav-item"><a class="nav-link" href="/sell">Sell</a></li>
          <li class="nav-item"><a class="nav-link disabled" href="#">Reports</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <div class="container mt-5">
    <h1 class="dashboard-title mb-4"><i class="fa-solid fa-shirt me-2"></i>Clothing Store Management</h1>
    <div class="row">
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><i class="fa-solid fa-box"></i> Manage Products</h5>
            <p class="card-text">Add, edit, and view products. Generate QR codes.</p>
            <a href="/products" class="btn btn-primary"><i class="fa-solid fa-list me-1"></i> Go to Products</a>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><i class="fa-solid fa-barcode"></i> Scan QR Code</h5>
            <p class="card-text">Scan a product QR code to start a sale.</p>
            <a href="/scan" class="btn btn-success"><i class="fa-solid fa-qrcode me-1"></i> Open Scanner</a>
          </div>
        </div>
      </div>
      <div class="col-md-4 mb-3">
        <div class="card">
          <div class="card-body">
            <h5 class="card-title"><i class="fa-solid fa-money-bill-wave"></i> New Sale</h5>
            <p class="card-text">Manually select a product and create a sale.</p>
            <a href="/sell" class="btn btn-warning"><i class="fa-solid fa-cart-plus me-1"></i> Create Sale</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>